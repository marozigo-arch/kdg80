---
import type { FestivalRoute } from '../lib/routes';

interface Props {
  route: FestivalRoute;
  programHref: string;
}

const { route, programHref } = Astro.props;
const variants = route.heroMyths.length ? route.heroMyths : route.myths;
const defaultVariant = variants[0];
const variantsPayload = JSON.stringify(variants);
---

<section class="route-hero" data-route-hero data-route-variants={variantsPayload} data-route-index="0">
  <div class="container route-hero__shell">
    <div class="route-hero__copy">
      <p class="route-hero__eyebrow">Маршрут по интересам</p>
      <h1>{route.title}</h1>
      <p class="route-hero__description">{route.description}</p>
      <div class="route-hero__meta">
        <span>{route.events.length} событий в подборке</span>
        <span>{Math.max(route.heroMyths.length, route.myths.length)} мифов в ротации</span>
      </div>
      <div class="route-hero__static-actions">
        <a class="button button--ghost" href={programHref}>К программе</a>
      </div>
    </div>

    {defaultVariant && (
      <div class="route-hero__myth-card" data-route-hero-card>
        <div class="route-hero__ambient" aria-hidden="true">
          {defaultVariant.ambientImage && (
            <img data-route-hero-image src={defaultVariant.ambientImage} alt="" loading="eager" decoding="async" />
          )}
        </div>

        <div class="route-hero__myth-body">
          <p class="route-hero__myth-label">Миф:</p>
          <a class="route-hero__myth-link" data-route-hero-link href={defaultVariant.eventHref}>
            {defaultVariant.text}
          </a>
          <p class="route-hero__speaker-line" data-route-hero-context>{defaultVariant.speakerLine}</p>

          <div class="route-hero__actions">
            <a class="button button--primary" data-route-hero-cta href={defaultVariant.eventHref}>К событию</a>
            {variants.length > 1 && (
              <button class="button button--ghost" type="button" data-route-hero-next>Следующий миф</button>
            )}
          </div>
        </div>
      </div>
    )}
  </div>
</section>

<script is:inline>
  const routeHero = document.querySelector('[data-route-hero]');

  const buildDeck = (variants) => {
    const deck = [...variants.keys()];
    for (let index = deck.length - 1; index > 0; index -= 1) {
      const nextIndex = Math.floor(Math.random() * (index + 1));
      [deck[index], deck[nextIndex]] = [deck[nextIndex], deck[index]];
    }
    return deck;
  };

  const setRouteHeroVariant = (root, variant, index) => {
    root.dataset.routeIndex = String(index);
    const image = root.querySelector('[data-route-hero-image]');
    const mythLink = root.querySelector('[data-route-hero-link]');
    const speakerLine = root.querySelector('[data-route-hero-context]');
    const cta = root.querySelector('[data-route-hero-cta]');

    if (image instanceof HTMLImageElement) {
      if (variant.ambientImage) {
        image.hidden = false;
        image.src = variant.ambientImage;
      } else {
        image.hidden = true;
        image.removeAttribute('src');
      }
    }

    if (mythLink instanceof HTMLAnchorElement) {
      mythLink.textContent = variant.text;
      mythLink.href = variant.eventHref;
    }

    if (speakerLine instanceof HTMLElement) {
      speakerLine.textContent = variant.speakerLine;
    }

    if (cta instanceof HTMLAnchorElement) {
      cta.href = variant.eventHref;
    }
  };

  if (routeHero instanceof HTMLElement && routeHero.dataset.routeVariants) {
    try {
      const variants = JSON.parse(routeHero.dataset.routeVariants);
      if (Array.isArray(variants) && variants.length > 1) {
        const nextButton = routeHero.querySelector('[data-route-hero-next]');
        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        let deck = buildDeck(variants);
        let deckIndex = 0;
        let timer = 0;

        const goToIndex = (nextDeckIndex) => {
          routeHero.dataset.switching = 'true';
          window.setTimeout(() => {
            setRouteHeroVariant(routeHero, variants[deck[nextDeckIndex]], nextDeckIndex);
            routeHero.dataset.switching = 'false';
          }, prefersReducedMotion ? 0 : 130);
        };

        const queueNext = () => {
          if (prefersReducedMotion) {
            return;
          }

          if (timer) {
            window.clearTimeout(timer);
          }

          timer = window.setTimeout(() => {
            deckIndex += 1;
            if (deckIndex >= deck.length) {
              deck = buildDeck(variants);
              deckIndex = 0;
            }
            goToIndex(deckIndex);
            queueNext();
          }, 6000);
        };

        setRouteHeroVariant(routeHero, variants[deck[deckIndex]], deckIndex);
        queueNext();

        if (nextButton instanceof HTMLButtonElement) {
          nextButton.addEventListener('click', () => {
            deckIndex += 1;
            if (deckIndex >= deck.length) {
              deck = buildDeck(variants);
              deckIndex = 0;
            }
            goToIndex(deckIndex);
            queueNext();
          });
        }

        routeHero.addEventListener('mouseenter', () => {
          if (timer) {
            window.clearTimeout(timer);
            timer = 0;
          }
        });

        routeHero.addEventListener('mouseleave', () => {
          queueNext();
        });
      }
    } catch (error) {
      console.error('Route hero hydration failed', error);
    }
  }
</script>


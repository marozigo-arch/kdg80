---
import type { FestivalRoute } from '../lib/routes';

interface Props {
  route: FestivalRoute;
  routeProgramHref: string;
}

const { route, routeProgramHref } = Astro.props;
const variants = route.heroMyths.length ? route.heroMyths : route.myths;
const defaultVariant = variants[0];
const variantsPayload = JSON.stringify(variants);
const defaultWords = defaultVariant ? getWordParts(defaultVariant.text) : [];
const defaultWordRevealStyle = getWordRevealStyle(defaultWords.length);
const defaultSpeakerLineParts = defaultVariant ? getMythContextParts(defaultVariant.speakerLine) : null;

function getWordParts(value: string) {
  return value.trim().split(/\s+/u).filter(Boolean);
}

function getWordRevealTiming(wordCount: number) {
  const safeCount = Math.max(wordCount, 1);
  const duration = 400;
  const totalWindow = 720;
  const stagger = safeCount > 1
    ? Math.max(18, Math.min(46, Math.round((totalWindow - duration) / (safeCount - 1))))
    : 0;
  return { stagger, duration };
}

function getWordRevealStyle(wordCount: number) {
  const { stagger, duration } = getWordRevealTiming(wordCount);
  return `--word-reveal-stagger: ${stagger}ms; --word-reveal-duration: ${duration}ms;`;
}

function getMythLabel(mythNumber?: number) {
  return mythNumber ? `Заблуждение #${mythNumber}` : 'Заблуждение';
}

function getMythContextParts(value: string) {
  const match = value.match(/заблуждени[а-я]*/iu);
  if (!match || typeof match.index !== 'number') {
    return {
      before: value,
      accent: '',
      after: '',
    };
  }

  return {
    before: value.slice(0, match.index),
    accent: match[0],
    after: value.slice(match.index + match[0].length),
  };
}
---

<section class="route-hero" data-route-hero data-route-variants={variantsPayload} data-route-index="0">
  <div class="container route-hero__shell">
    {defaultVariant && (
      <div class="route-hero__myth-card" data-route-hero-card>
        <div class="route-hero__brandbadge" aria-hidden="true">
          <img src="/shared-assets/logo-80-istorii-hero.svg" alt="" width="431" height="373" decoding="async" loading="eager" />
        </div>
        <div class="route-hero__myth-body">
          <p class="route-hero__myth-label" data-route-hero-label>{getMythLabel(defaultVariant.mythNumber)}</p>
          <a
            class="route-hero__myth-link word-reveal"
            data-route-hero-link
            data-word-reveal
            href={defaultVariant.eventHref}
            style={defaultWordRevealStyle}
          >
            {defaultWords.map((word, index) => (
              <>
                <span class="word-reveal__word" style={`--word-index: ${index};`}>{word}</span>
                {index < defaultWords.length - 1 && ' '}
              </>
            ))}
          </a>
          <p class="route-hero__speaker-line" data-route-hero-context>
            {defaultSpeakerLineParts
              ? (
                <>
                  {defaultSpeakerLineParts.before}
                  {defaultSpeakerLineParts.accent && <span class="myth-context__accent">{defaultSpeakerLineParts.accent}</span>}
                  {defaultSpeakerLineParts.after}
                </>
              )
              : defaultVariant.speakerLine}
          </p>

          <div class="route-hero__actions">
            <a class="button button--primary" data-route-hero-cta href={defaultVariant.eventHref}>К событию</a>
            {variants.length > 1 && (
              <button class="button button--ghost" type="button" data-route-hero-next>Следующий миф</button>
            )}
          </div>
        </div>
      </div>
    )}

    <div class="route-hero__copy">
      <p class="route-hero__eyebrow">Маршрут по интересам</p>
      <h1>{route.title}</h1>
      <p class="route-hero__description">{route.description}</p>
      <div class="route-hero__meta">
        <span>{route.events.length} событий в подборке</span>
      </div>
      <div class="route-hero__static-actions">
        <a class="button button--ghost" href={routeProgramHref}>К программе маршрута</a>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  const routeHero = document.querySelector('[data-route-hero]');
  const DESKTOP_ROUTE_HERO_AUTOPLAY_MS = 9000;

  const isHeavyMyth = (variant) => /уничтож|разруш|невозможно спасти/iu.test(String(variant?.text ?? ''));

  const buildDeck = (variants, avoidFirstIndex = -1) => {
    const deck = [...variants.keys()];
    for (let index = deck.length - 1; index > 0; index -= 1) {
      const nextIndex = Math.floor(Math.random() * (index + 1));
      [deck[index], deck[nextIndex]] = [deck[nextIndex], deck[index]];
    }

    const firstSoftIndex = deck.findIndex((deckItem) => !isHeavyMyth(variants[deckItem]));
    if (firstSoftIndex > 0 && isHeavyMyth(variants[deck[0]])) {
      [deck[0], deck[firstSoftIndex]] = [deck[firstSoftIndex], deck[0]];
    }

    for (let index = 1; index < deck.length; index += 1) {
      const previousVariant = variants[deck[index - 1]];
      const currentVariant = variants[deck[index]];
      const sameEvent = previousVariant?.eventTitle && currentVariant?.eventTitle
        && previousVariant.eventTitle === currentVariant.eventTitle;
      const sameHeavyCluster = isHeavyMyth(previousVariant) && isHeavyMyth(currentVariant);

      if (!sameEvent && !sameHeavyCluster) {
        continue;
      }

      const swapIndex = deck.findIndex((deckItem, candidateIndex) => {
        if (candidateIndex <= index) {
          return false;
        }

        const candidate = variants[deckItem];
        const avoidsSameEvent = !previousVariant?.eventTitle || candidate?.eventTitle !== previousVariant.eventTitle;
        const avoidsHeavyCluster = !(isHeavyMyth(previousVariant) && isHeavyMyth(candidate));
        return avoidsSameEvent && avoidsHeavyCluster;
      });

      if (swapIndex > index) {
        [deck[index], deck[swapIndex]] = [deck[swapIndex], deck[index]];
      }
    }

    if (deck.length > 1 && avoidFirstIndex >= 0 && deck[0] === avoidFirstIndex) {
      const nextIndex = deck.findIndex((deckItem) => deckItem !== avoidFirstIndex);
      if (nextIndex > 0) {
        [deck[0], deck[nextIndex]] = [deck[nextIndex], deck[0]];
      }
    }

    return deck;
  };

  const setWordRevealText = (element, text, animate) => {
    if (!(element instanceof HTMLElement)) {
      return;
    }

    const words = String(text ?? '').trim().split(/\s+/u).filter(Boolean);
    element.textContent = '';
    element.classList.add('word-reveal');
    const safeCount = Math.max(Number(words.length) || 1, 1);
    const duration = 400;
    const totalWindow = 720;
    const stagger = safeCount > 1
      ? Math.max(18, Math.min(46, Math.round((totalWindow - duration) / (safeCount - 1))))
      : 0;
    element.style.setProperty('--word-reveal-stagger', `${stagger}ms`);
    element.style.setProperty('--word-reveal-duration', `${duration}ms`);

    if (!words.length) {
      return;
    }

    const fragment = document.createDocumentFragment();
    words.forEach((word, index) => {
      const span = document.createElement('span');
      span.className = 'word-reveal__word';
      span.style.setProperty('--word-index', String(index));
      span.textContent = word;
      if (!animate) {
        span.dataset.static = 'true';
      }
      fragment.append(span);
      if (index < words.length - 1) {
        fragment.append(document.createTextNode(' '));
      }
    });

    element.append(fragment);
  };

  const setMythContextText = (element, text) => {
    if (!(element instanceof HTMLElement)) {
      return;
    }

    const value = String(text ?? '');
    const match = value.match(/заблуждени[а-я]*/iu);
    element.textContent = '';

    if (!match || typeof match.index !== 'number') {
      element.textContent = value;
      return;
    }

    element.append(document.createTextNode(value.slice(0, match.index)));
    const accent = document.createElement('span');
    accent.className = 'myth-context__accent';
    accent.textContent = match[0];
    element.append(accent);
    element.append(document.createTextNode(value.slice(match.index + match[0].length)));
  };

  const setRouteHeroVariant = (root, variant, index) => {
    root.dataset.routeIndex = String(index);
    const label = root.querySelector('[data-route-hero-label]');
    const mythLink = root.querySelector('[data-route-hero-link]');
    const speakerLine = root.querySelector('[data-route-hero-context]');
    const cta = root.querySelector('[data-route-hero-cta]');
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (label instanceof HTMLElement) {
      label.textContent = variant.mythNumber ? `Заблуждение #${variant.mythNumber}` : 'Заблуждение';
    }

    if (mythLink instanceof HTMLAnchorElement) {
      mythLink.href = variant.eventHref;
      setWordRevealText(mythLink, variant.text, !reducedMotion);
    }

    if (speakerLine instanceof HTMLElement) {
      setMythContextText(speakerLine, variant.speakerLine);
    }

    if (cta instanceof HTMLAnchorElement) {
      cta.href = variant.eventHref;
    }
  };

  if (routeHero instanceof HTMLElement && routeHero.dataset.routeVariants) {
    try {
      const variants = JSON.parse(routeHero.dataset.routeVariants);
      if (Array.isArray(variants) && variants.length > 1) {
        const nextButton = routeHero.querySelector('[data-route-hero-next]');
        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const isMobile = window.matchMedia('(max-width: 759px), (pointer: coarse)').matches;
        let deck = buildDeck(variants);
        let deckIndex = 0;
        let timer = 0;
        let userInteracted = false;

        const goToIndex = (nextDeckIndex) => {
          routeHero.dataset.switching = 'true';
          window.setTimeout(() => {
            setRouteHeroVariant(routeHero, variants[deck[nextDeckIndex]], nextDeckIndex);
            routeHero.dataset.switching = 'false';
          }, prefersReducedMotion ? 0 : 220);
        };

        const resetDeck = (lastShownIndex = -1) => {
          deck = buildDeck(variants, lastShownIndex);
          deckIndex = 0;
        };

        const queueNext = () => {
          if (prefersReducedMotion || isMobile || userInteracted) {
            return;
          }

          if (timer) {
            window.clearTimeout(timer);
          }

          timer = window.setTimeout(() => {
            const currentVariantIndex = deck[deckIndex];
            deckIndex += 1;
            if (deckIndex >= deck.length) {
              resetDeck(currentVariantIndex);
            }
            goToIndex(deckIndex);
            queueNext();
          }, DESKTOP_ROUTE_HERO_AUTOPLAY_MS);
        };

        setRouteHeroVariant(routeHero, variants[deck[deckIndex]], deckIndex);
        queueNext();

        if (nextButton instanceof HTMLButtonElement) {
          nextButton.addEventListener('click', () => {
            userInteracted = true;
            if (timer) {
              window.clearTimeout(timer);
              timer = 0;
            }
            const currentVariantIndex = deck[deckIndex];
            deckIndex += 1;
            if (deckIndex >= deck.length) {
              resetDeck(currentVariantIndex);
            }
            goToIndex(deckIndex);
          });
        }

        routeHero.addEventListener('mouseenter', () => {
          if (timer) {
            window.clearTimeout(timer);
            timer = 0;
          }
        });

        routeHero.addEventListener('mouseleave', () => {
          queueNext();
        });
      } else if (Array.isArray(variants) && variants.length === 1) {
        setRouteHeroVariant(routeHero, variants[0], 0);
      }
    } catch (error) {
      console.error('Route hero hydration failed', error);
    }
  }
</script>

---
import Layout from '../layouts/Layout.astro';
import {
  getFestivalEvents,
  getMonthGroups,
  getOpenDialogues,
  getSpeakerShowcase,
} from '../lib/festival';

const events = getFestivalEvents();
const monthGroups = getMonthGroups(events);
const SPEAKER_SHOWCASE_LIMIT = 8;
const allSpeakerShowcase = getSpeakerShowcase(events, Number.POSITIVE_INFINITY);
const speakerShowcase = allSpeakerShowcase.slice(0, SPEAKER_SHOWCASE_LIMIT);
const openDialogues = getOpenDialogues(events).slice(0, 5);
const nextEvent = events[0];
const PRESS_EMAIL = 'press@kgd80.ru';
const FESTIVAL_REGULATION_URL = '/docs/festival-regulation.pdf';
const TELEGRAM_ANNOUNCEMENT_URL = 'https://t.me/kenigevents';
const TELEGRAM_CHANNEL_NAME = 'Полюбить Калининград Анонсы';
const TELEGRAM_CHANNEL_HANDLE = '@kenigevents';
const TELEGRAM_QR_CODE_URL = '/generated/telegram/kenigevents-qr.svg';
type RelatedEventCard = NonNullable<(typeof events)[number]['relatedEvent']>;
type SpeakerLectureLinkCard = (typeof events)[number]['speakerLectureLinks'][number];

const WEEKDAY_SHORT: Record<string, string> = {
  понедельник: 'пн',
  вторник: 'вт',
  среда: 'ср',
  четверг: 'чт',
  пятница: 'пт',
  суббота: 'сб',
  воскресенье: 'вс',
};

const SCIENTIFIC_LIBRARY_VISIT_SCHEDULE = {
  name: 'Калининградская областная научная библиотека',
  hoursLabel: 'Пн-чт 10:00-20:00, сб-вс 10:00-18:00, пт выходной',
  sanitaryLabel: 'Последний вторник месяца — санитарный день',
  sourceUrl: 'https://lib39.ru/aboutlibrary/grafic.php',
  sourceLabel: 'Официальный график библиотеки',
};

const EVENT_PORTRAIT_OVERRIDES: Array<{ match: string; style: string }> = [
  { match: 'Мосиенко', style: '--event-portrait-size: 1.24; --event-portrait-shift-x: 0.22rem; --event-portrait-shift-y: 0rem;' },
  { match: 'Соколов', style: '--event-portrait-size: 1; --event-portrait-shift-x: 0.08rem; --event-portrait-shift-y: 0rem;' },
  { match: 'Конюхова', style: '--event-portrait-size: 1.04; --event-portrait-shift-x: 0.08rem; --event-portrait-shift-y: 0rem;' },
  { match: 'Илюшкина', style: '--event-portrait-size: 1.03; --event-portrait-shift-x: 0.28rem; --event-portrait-shift-y: 0.14rem;' },
  { match: 'Долотова', style: '--event-portrait-size: 1.02; --event-portrait-shift-x: 0.1rem; --event-portrait-shift-y: 0.12rem;' },
  { match: 'Надымова', style: '--event-portrait-size: 1.04; --event-portrait-shift-x: 0.12rem; --event-portrait-shift-y: 0.12rem;' },
  { match: 'Ярцев', style: '--event-portrait-size: 1; --event-portrait-shift-x: 0.08rem; --event-portrait-shift-y: 0.16rem;' },
];

const LECTURE_EVENT_PORTRAIT_OVERRIDES: Array<{ match: string; style: string }> = [
  {
    match: 'Мосиенко',
    style: '--event-portrait-size: 1.04; --event-portrait-shift-x: 0.18rem; --event-portrait-shift-y: 0.08rem; --event-portrait-width-mobile: min(40.5%, 13rem); --event-portrait-width-desktop: min(39%, 13.2rem);',
  },
  {
    match: 'Конюхова',
    style: '--event-portrait-size: 0.9; --event-portrait-shift-x: 0.08rem; --event-portrait-shift-y: 0.04rem; --event-portrait-width-mobile: min(37%, 12.1rem); --event-portrait-width-desktop: min(36%, 12.35rem);',
  },
  {
    match: 'Сарниц',
    style: '--event-portrait-size: 1.08; --event-portrait-shift-x: -1.45rem; --event-portrait-shift-y: 0rem; --event-portrait-width-mobile: min(43%, 13.2rem); --event-portrait-width-desktop: min(40.5%, 13.6rem);',
  },
];

const LECTURE_PORTRAIT_IMAGE_OVERRIDES: Array<{ match: string; path: string }> = [
  { match: 'Мосиенко', path: '/generated/lecture-portraits/mosienko-evgeniy-lecture.webp' },
  { match: 'Конюхова', path: '/generated/lecture-portraits/tatyana-konyuhova-lecture.webp' },
  { match: 'Сарниц', path: '/generated/lecture-portraits/sarnits-artur-lecture.webp' },
];

const SPEAKER_STRIP_IMAGE_OVERRIDES: Array<{ match: string; path: string }> = [
  { match: 'Соколова', path: '/generated/speaker-strip/sokolova-svetlana.webp' },
  { match: 'Соколов', path: '/generated/speaker-strip/aleksey-sokolov.webp' },
  { match: 'Долотова', path: '/generated/speaker-strip/dolotova-inga.webp' },
  { match: 'Жадобко', path: '/generated/speaker-strip/zhadobko-sergey.webp' },
  { match: 'Илюшкина', path: '/generated/speaker-strip/ilyushkina-ekaterina.webp' },
  { match: 'Машинская', path: '/generated/speaker-strip/mashinskaya-ekaterina.webp' },
  { match: 'Мосиенко', path: '/generated/speaker-strip/mosienko-evgeniy.webp' },
  { match: 'Надымова', path: '/generated/speaker-strip/nadymova-valeriya.webp' },
  { match: 'Нижегородцева', path: '/generated/speaker-strip/nizhegorodtseva-evgeniya.webp' },
  { match: 'Попадин', path: '/generated/speaker-strip/popadin-aleksandr.webp' },
  { match: 'Скребцова', path: '/generated/speaker-strip/skrebtsova-anastasiya.webp' },
  { match: 'Конюхова', path: '/generated/speaker-strip/tatyana-konyuhova.webp' },
  { match: 'Удовенко', path: '/generated/speaker-strip/udovenko-tatyana.webp' },
  { match: 'Ярцев', path: '/generated/speaker-strip/yartsev-andrey-3.webp' },
];

const SPEAKER_STRIP_STYLE_OVERRIDES: Array<{ match: string; style: string }> = [
  { match: 'Конюхова', style: '--speaker-strip-scale-mobile: 0.352; --speaker-strip-scale-desktop: 0.458; --speaker-strip-x-mobile: -6px; --speaker-strip-x-desktop: -12px; --speaker-strip-y-mobile: -34px; --speaker-strip-y-desktop: -70px;' },
  { match: 'Жадобко', style: '--speaker-strip-scale-mobile: 0.314; --speaker-strip-scale-desktop: 0.383; --speaker-strip-y-mobile: 8px; --speaker-strip-y-desktop: 16px;' },
  { match: 'Марковец', style: '--speaker-strip-scale-mobile: 0.35; --speaker-strip-scale-desktop: 0.434; --speaker-strip-y-mobile: -18px; --speaker-strip-y-desktop: -32px;' },
  { match: 'Удовенко', style: '--speaker-strip-scale-mobile: 0.324; --speaker-strip-scale-desktop: 0.398; --speaker-strip-x-mobile: -12px; --speaker-strip-x-desktop: -18px; --speaker-strip-y-mobile: 14px; --speaker-strip-y-desktop: 20px;' },
  { match: 'Ситникова', style: '--speaker-strip-scale-mobile: 0.332; --speaker-strip-scale-desktop: 0.41; --speaker-strip-y-mobile: 14px; --speaker-strip-y-desktop: 20px;' },
];

const DIALOGUE_PORTRAIT_STYLE_OVERRIDES: Array<{ match: string; style: string }> = [
  { match: 'Удовенко', style: '--dialogue-portrait-scale-mobile: 0.236; --dialogue-portrait-scale-desktop: 0.226; --dialogue-portrait-x-mobile: 3px; --dialogue-portrait-x-desktop: 6px;' },
  { match: 'Сивкова', style: '--dialogue-portrait-scale-mobile: 0.222; --dialogue-portrait-scale-desktop: 0.212;' },
  { match: 'Жадобко', style: '--dialogue-portrait-scale-mobile: 0.217; --dialogue-portrait-scale-desktop: 0.208;' },
  { match: 'Попадин', style: '--dialogue-portrait-scale-mobile: 0.214; --dialogue-portrait-scale-desktop: 0.206;' },
  { match: 'Литвинович', style: '--dialogue-portrait-scale-mobile: 0.219; --dialogue-portrait-scale-desktop: 0.208; --dialogue-portrait-x-mobile: -3px; --dialogue-portrait-x-desktop: -6px;' },
  { match: 'Бойко', style: '--dialogue-portrait-scale-mobile: 0.219; --dialogue-portrait-scale-desktop: 0.208;' },
  { match: 'Марковец', style: '--dialogue-portrait-scale-mobile: 0.221; --dialogue-portrait-scale-desktop: 0.212;' },
  { match: 'Никитин', style: '--dialogue-portrait-scale-mobile: 0.221; --dialogue-portrait-scale-desktop: 0.21;' },
  { match: 'Сарниц', style: '--dialogue-portrait-x-desktop: 22px;' },
  { match: 'Долотова', style: '--dialogue-portrait-scale-mobile: 0.218; --dialogue-portrait-scale-desktop: 0.208;' },
  { match: 'Ярцев', style: '--dialogue-portrait-scale-mobile: 0.216; --dialogue-portrait-scale-desktop: 0.206;' },
];

function getDateParts(dateLabel: string) {
  const match = dateLabel.match(/(\d{1,2})\s+([а-я]+)\s+2026(?:\s+\(([^)]+)\))?/i);
  if (!match) {
    return {
      day: '??',
      month: 'скоро',
      weekday: '',
    };
  }

  return {
    day: match[1],
    month: match[2].toLowerCase(),
    weekday: WEEKDAY_SHORT[(match[3] ?? '').toLowerCase()] ?? '',
  };
}

function getRangeDateParts(dateLabel: string) {
  const match = dateLabel.match(/(?:с\s*)?(\d{1,2})\s+([а-я]+)(?:\s+\d{4})?\s*(?:-|—|–|по)\s*(\d{1,2})\s+([а-я]+)\s+(\d{4})/i);
  if (!match) {
    return null;
  }

  return {
    startDay: match[1],
    startMonth: match[2].toLowerCase(),
    endDay: match[3],
    endMonth: match[4].toLowerCase(),
  };
}

function getCardText(event: { whyGo: string; summary: string }) {
  return event.summary || event.whyGo;
}

function getCardExtraText(event: { whyGo: string; summary: string }) {
  if (!event.whyGo) {
    return '';
  }

  return event.whyGo !== event.summary ? event.whyGo : '';
}

function getRelatedMetaLine(relatedEvent: RelatedEventCard) {
  const parts = [relatedEvent.formatLabel, relatedEvent.dateLabel];

  if (relatedEvent.kind !== 'range' && !relatedEvent.timeLabel.includes('будет объявлено')) {
    parts.push(relatedEvent.timeLabel);
  }

  return parts.filter(Boolean).join(' · ');
}

function getRelatedSecondaryLine(relatedEvent: RelatedEventCard) {
  const parts = relatedEvent.kind === 'range'
    ? [relatedEvent.venue, relatedEvent.address]
    : [relatedEvent.speakerLabel, relatedEvent.venue];

  return parts.filter(Boolean).join(' · ');
}


function getLectureTitleClass(title: string) {
  const length = title.trim().length;

  if (length >= 88) {
    return 'event-card__visual-title event-card__visual-title--xxlong';
  }

  if (length >= 64) {
    return 'event-card__visual-title event-card__visual-title--xlong';
  }

  if (length >= 46) {
    return 'event-card__visual-title event-card__visual-title--long';
  }

  return 'event-card__visual-title';
}

function getPortraitFrames(name: string, images: string[], isLecture = false) {
  return images
    .map((image) => getEventPortraitImage(name, image, isLecture))
    .join('|');
}

function getEventPortraitImages(name: string, images: string[], isLecture = false) {
  return images.map((image) => getEventPortraitImage(name, image, isLecture));
}

function getSpeakerCaption(value: string) {
  if (!value) {
    return '';
  }

  return value.replace(/\s+/g, ' ').trim();
}

function getSpeakerStripImage(name: string, fallback: string) {
  return SPEAKER_STRIP_IMAGE_OVERRIDES.find((entry) => name.includes(entry.match))?.path
    ?? fallback.replace('/generated/speakers/', '/generated/speaker-strip/');
}

function getEventPortraitImage(name: string, fallback: string, isLecture = false) {
  if (isLecture) {
    const lectureOverride = LECTURE_PORTRAIT_IMAGE_OVERRIDES.find((entry) => name.includes(entry.match))?.path;
    if (lectureOverride) {
      return lectureOverride;
    }
  }

  return getSpeakerStripImage(name, fallback);
}

function getSpeakerStripStyle(name: string) {
  return SPEAKER_STRIP_STYLE_OVERRIDES.find((entry) => name.includes(entry.match))?.style;
}

const speakerShowcasePayload = JSON.stringify(
  allSpeakerShowcase.map((speaker) => ({
    name: speaker.name,
    affiliation: speaker.affiliation,
    anchor: speaker.anchor,
    weight: speaker.weight,
    image: getSpeakerStripImage(speaker.name, speaker.images[0]),
    style: getSpeakerStripStyle(speaker.name) ?? '',
  })),
);

function getDialoguePortraitImage(name: string, fallback: string) {
  return getSpeakerStripImage(name, fallback);
}

function getDialoguePortraitStyle(name: string) {
  return DIALOGUE_PORTRAIT_STYLE_OVERRIDES.find((entry) => name.includes(entry.match))?.style
    ?? undefined;
}

function getEventPortraitStyle(value: string, isLecture = false) {
  if (isLecture) {
    const lectureStyle = LECTURE_EVENT_PORTRAIT_OVERRIDES.find((entry) => value.includes(entry.match))?.style;
    if (lectureStyle) {
      return lectureStyle;
    }
  }

  return EVENT_PORTRAIT_OVERRIDES.find((entry) => value.includes(entry.match))?.style ?? undefined;
}

function isLectureEvent(formatLabel: string) {
  return formatLabel.toLowerCase().includes('лекц');
}

function isOpeningEvent(event: { title: string; format: string }) {
  return event.title === 'Открытие фестиваля' || event.format.includes('Открытие фестиваля');
}

function usesScientificLibraryVisitSchedule(event: { kind: string; venue: string; timeLabel: string }) {
  if (event.kind !== 'range') {
    return false;
  }

  const venueLookup = event.venue.toLowerCase();
  const timeLookup = event.timeLabel.toLowerCase();

  return (
    (venueLookup.includes('науч') && venueLookup.includes('библиот')) ||
    (timeLookup.includes('часы работы') && timeLookup.includes('библиот'))
  );
}

function getRangeVisitLabel(event: { timeLabel: string }, useScientificLibraryVisitSchedule: boolean) {
  if (useScientificLibraryVisitSchedule) {
    return SCIENTIFIC_LIBRARY_VISIT_SCHEDULE.hoursLabel;
  }

  return event.timeLabel;
}

function getDialogueMonogram(name: string) {
  return name
    .split(/\s+/)
    .filter(Boolean)
    .slice(0, 2)
    .map((part) => part[0]?.toUpperCase() ?? '')
    .join('');
}
---

<Layout
  title="80 историй о главном | Прототип главной страницы"
  description="Афишный прототип фестиваля: image-first программа, плотный обзор длинной ленты и крупные портреты спикеров."
>
  <div class="page">
    <header class="site-header">
      <div class="container site-header__row">
        <a class="site-header__logo" href="#top" aria-label="Российское общество Знание">
          <img src="/shared-assets/logo-znanie.svg" alt="Логотип Российского общества Знание" width="647" height="150" />
        </a>

        <nav class="site-header__nav" aria-label="Быстрые разделы">
          <a href="#speakers">Спикеры</a>
          <a href="#program">Программа</a>
          <a href="#dialogues">Диалоги</a>
          <a href="#press">СМИ</a>
        </nav>

        <a class="button button--primary site-header__cta" href="#program">Программа</a>
      </div>
    </header>

    <main id="top">
      <section class="hero">
        <div class="container">
          <div class="hero__shell">
            <div class="hero__copy">
              <p class="eyebrow">Просветительский фестиваль Российского общества Знание</p>
              <p class="hero__kicker">К 80-летию Калининградской области</p>
              <h1>80 историй о главном</h1>
              <p class="hero__lead">
                В десктопе программа должна ощущаться как живая афиша, а не как длинный корпоративный реестр.
                Поэтому главный вход здесь через изображение, дату, человека и одно сильное обещание события.
              </p>

              <div class="hero__meta" aria-label="Ключевые параметры фестиваля">
                <span>Калининград</span>
                <span>28 марта - 19 июля 2026</span>
                <span>{events.length} событий в текущей сборке</span>
              </div>

              <div class="hero__actions">
                <a class="button button--primary" href="#program">Смотреть программу</a>
                <a class="button button--ghost" href="#announces">Подписаться на анонсы</a>
              </div>

              <p class="hero__note">
                Приоритетный сценарий: быстро выбрать несколько событий подряд и не потерять их.
              </p>
            </div>

            <aside class="hero__aside" aria-label="Ближайшее событие и визуальная атмосфера">
              <article class="hero-ticket">
                <p class="hero-ticket__eyebrow">Ближайшее событие</p>
                <h2>{nextEvent.title}</h2>
                <div class="hero-ticket__meta">
                  <span>{nextEvent.dateLabel}</span>
                  <span>{nextEvent.timeLabel}</span>
                  <span>{nextEvent.venue}</span>
                </div>
                <a class="button button--light" href={`#event-${nextEvent.slug}`}>К событию</a>
              </article>

              <div class="hero-mosaic" aria-hidden="true">
                <figure class="hero-mosaic__item hero-mosaic__item--large">
                  <img src={nextEvent.image} alt="" loading="eager" />
                </figure>
                <figure class="hero-mosaic__item hero-mosaic__item--tall">
                  <img src="/shared-assets/hero-added-04.webp" alt="" loading="lazy" />
                </figure>
                <figure class="hero-mosaic__item hero-mosaic__item--wide">
                  <img src="/shared-assets/hero-added-09.webp" alt="" loading="lazy" />
                </figure>
              </div>
            </aside>
          </div>
        </div>
      </section>

      <section class="section speaker-section" id="speakers">
        <div class="container">
          <div class="speaker-poster">
            <div class="speaker-poster__masthead">
              <div class="speaker-poster__topline">
                <p class="speaker-poster__eyebrow">Люди фестиваля</p>
                <p class="speaker-poster__stamp">Калининград / 2026 / 80 историй о главном</p>
              </div>

              <h2>
                <span>ГОЛОСА</span>
                <span>ФЕСТИВАЛЯ</span>
              </h2>

              <p class="speaker-poster__note">
                Крупные лица, резкий кроп, без карточного воздуха.
              </p>
            </div>

            <div
              class="speaker-strip"
              data-visible-count={SPEAKER_SHOWCASE_LIMIT}
              data-speakers={speakerShowcasePayload}
            >
              {speakerShowcase.map((speaker, index) => (
                <a class={`speaker-entry speaker-entry--${index + 1}`} href={`#${speaker.anchor}`}>
                  <div class="speaker-entry__meta">
                    <strong>{speaker.name}</strong>
                    {speaker.affiliation && <span>{getSpeakerCaption(speaker.affiliation)}</span>}
                  </div>

                  <div class="speaker-entry__media">
                    <img
                      class="speaker-entry__portrait"
                      src={getSpeakerStripImage(speaker.name, speaker.images[0])}
                      alt={speaker.name}
                      loading="eager"
                      style={getSpeakerStripStyle(speaker.name)}
                    />
                  </div>
                </a>
              ))}
            </div>
          </div>
        </div>
      </section>

      <section class="section section--compact" id="dialogues">
        <div class="container">
          <div class="section__header section__header--split">
            <div>
              <p class="section__eyebrow">Открытые диалоги</p>
              <h2>Их нужно выделять как отдельную драматургию фестиваля, а не как ещё один тип карточки</h2>
            </div>
            <p class="section__text">
              Здесь оставляю короткий ряд афишных анонсов: многоголосие, столкновение точек зрения и ощущение публичного разговора.
            </p>
          </div>

          <div class="dialogue-strip">
            {openDialogues.map((event) => (
              <a class="dialogue-card" href={`#event-${event.slug}`}>
                <span class="dialogue-card__meta">{event.dateLabel}</span>
                <strong>{event.title}</strong>
                <span>{event.venue}</span>
              </a>
            ))}
          </div>
        </div>
      </section>

      <section class="section section--program" id="program">
        <div class="container">
          <div class="section__header section__header--split">
            <div>
              <p class="section__eyebrow">Программа</p>
              <h2>Вся лента должна сканироваться быстро: дата, картинка, спикер и минимум ключевой информации</h2>
            </div>
            <p class="section__text">
              На десктопе перестраиваю список в плотный image-first ритм. Длинные абзацы убраны из первого экрана карточки,
              а на первый план выходят дата, афиша события и заметный человек.
            </p>
          </div>

          <div class="month-nav-wrap">
            <nav class="month-nav" aria-label="Навигация по месяцам">
              {monthGroups.map((group) => (
                <a href={`#month-${group.anchor}`}>{group.label}</a>
              ))}
            </nav>
          </div>

          <div class="program">
            {monthGroups.map((group) => (
              <section class="month-block" id={`month-${group.anchor}`}>
                <header class="month-block__header">
                  <div>
                    <p class="month-block__eyebrow">2026</p>
                    <h3>{group.label}</h3>
                  </div>
                  <span class="month-block__count">{group.events.length} событий</span>
                </header>

                <div class="event-list">
                  {group.events.map((event) => {
                    const dateParts = getDateParts(event.dateLabel);
                    const rangeDateParts = event.kind === 'range' ? getRangeDateParts(event.dateLabel) : null;
                    const isDialogueEvent = event.formatLabel.includes('Открытый диалог') && event.dialogueParticipants.length > 0;
                    const isSpecialEvent = event.kind === 'special';
                    const isLecture = isLectureEvent(event.formatLabel);
                    const openingEvent = isOpeningEvent(event);
                    const stageImage = event.image || (openingEvent ? '/shared-assets/hero-added-09.webp' : '');
                    const useDialogueVisual = isDialogueEvent && !openingEvent;
                    const portraitImages = getEventPortraitImages(event.speakerLabel, event.speakerImages, isLecture);
                    const portraitFrames = getPortraitFrames(event.speakerLabel, event.speakerImages, isLecture);
                    const portraitStyle = getEventPortraitStyle(event.speakerLabel, isLecture);
                    const visualDialogueParticipants = useDialogueVisual
                      ? event.dialogueParticipants.filter((participant) => participant.images[0]).slice(0, 4)
                      : [];
                    const dialogueStageParticipants = visualDialogueParticipants.length
                      ? visualDialogueParticipants
                      : event.dialogueParticipants.slice(0, 4);
                    const cardText = getCardText(event);
                    const cardExtraText = getCardExtraText(event);
                    const useScientificLibraryVisitSchedule = usesScientificLibraryVisitSchedule(event);

                    return (
                      <article class={`event-card ${event.speakerImages.length ? 'event-card--with-speaker' : ''} ${isLecture ? 'event-card--lecture' : ''} ${isDialogueEvent ? 'event-card--dialogue' : ''} ${isSpecialEvent ? 'event-card--special' : ''}`} id={`event-${event.slug}`}>
                        <div class="event-card__main">
                          <div class={`event-card__stage ${!useDialogueVisual && event.speakerImages.length > 0 ? 'event-card__stage--portrait' : ''}`}>
                            {isSpecialEvent ? (
                              <div class={`event-card__visual ${stageImage ? 'event-card__visual--special' : 'event-card__visual--plain event-card__visual--special'}`}>
                                {stageImage && (
                                  <img class="event-card__poster" src={stageImage} alt={`Афиша: ${event.title}`} loading="lazy" />
                                )}
                                <div class="event-card__overlay"></div>
                                <div class="event-card__special-shell">
                                  <p class="event-card__special-eyebrow">Спецсобытие фестиваля</p>
                                  <p class="event-card__special-status">Дата будет объявлена дополнительно</p>
                                  {event.showingsLabel && <p class="event-card__special-meta">{event.showingsLabel} показа</p>}
                                </div>
                              </div>
                            ) : (
                              <>
                                <div class="event-card__date">
                                  {rangeDateParts ? (
                                    <>
                                      <span class="event-card__range-row">
                                        <span class="event-card__range-prefix">с</span>
                                        <span class="event-card__range-day">{rangeDateParts.startDay}</span>
                                        <span class="event-card__range-month">{rangeDateParts.startMonth}</span>
                                      </span>
                                      <span class="event-card__range-row">
                                        <span class="event-card__range-prefix">по</span>
                                        <span class="event-card__range-day">{rangeDateParts.endDay}</span>
                                        <span class="event-card__range-month">{rangeDateParts.endMonth}</span>
                                      </span>
                                    </>
                                  ) : (
                                    <>
                                      <span class="event-card__day">{dateParts.day}</span>
                                      <span class="event-card__month">{dateParts.month}</span>
                                      {dateParts.weekday && <span class="event-card__weekday">{dateParts.weekday}</span>}
                                      <span class="event-card__time">{event.timeLabel}</span>
                                    </>
                                  )}
                                </div>

                                {useDialogueVisual ? (
                                  <div
                                    class="event-card__dialogue-visual"
                                    aria-label={`Участники события ${event.title}`}
                                    style={`--dialogue-columns: ${Math.max(dialogueStageParticipants.length, 1)}`}
                                  >
                                    {dialogueStageParticipants.map((participant) => (
                                      <div class={`event-card__dialogue-person ${participant.images[0] ? '' : 'event-card__dialogue-person--placeholder'}`}>
                                        <div class="event-card__dialogue-meta">
                                          <strong>{participant.name}</strong>
                                        </div>
                                        <div class={`event-card__dialogue-media ${participant.images[0] ? '' : 'event-card__dialogue-media--placeholder'}`}>
                                          {participant.images[0] ? (
                                            <img
                                              class="event-card__dialogue-portrait"
                                              src={getDialoguePortraitImage(participant.name, participant.images[0])}
                                              alt={participant.name}
                                              loading="lazy"
                                              style={getDialoguePortraitStyle(participant.name)}
                                            />
                                          ) : (
                                            <span class="event-card__dialogue-placeholder" aria-hidden="true">
                                              {getDialogueMonogram(participant.name)}
                                            </span>
                                          )}
                                        </div>
                                      </div>
                                    ))}
                                  </div>
                                ) : (
                                  <>
                                    <div class={`event-card__visual ${stageImage ? '' : 'event-card__visual--plain'}`}>
                                      {stageImage && (
                                        <img class="event-card__poster" src={stageImage} alt={`Афиша: ${event.title}`} loading="lazy" />
                                      )}
                                      <div class="event-card__overlay"></div>

                                      {isLecture && (
                                        <div class="event-card__visual-copy">
                                          <p class={getLectureTitleClass(event.title)}>{event.title}</p>
                                        </div>
                                      )}
                                    </div>

                                    {event.speakerImages.length > 0 && (
                                      <div
                                        class="event-card__portrait portrait-cycle"
                                        data-portrait-frames={portraitFrames}
                                        style={portraitStyle}
                                      >
                                        <img
                                          class="portrait-cycle__image is-active"
                                          src={portraitImages[0]}
                                          alt={event.speakerLabel}
                                          loading="lazy"
                                        />
                                        {portraitImages.length > 1 && (
                                          <img
                                            class="portrait-cycle__image"
                                            src={portraitImages[1]}
                                            alt={event.speakerLabel}
                                            loading="lazy"
                                            aria-hidden="true"
                                          />
                                        )}
                                      </div>
                                    )}
                                  </>
                                )}
                              </>
                            )}
                          </div>

                          <div class="event-card__body">
                            <div class="event-card__body-head">
                              <span class="event-card__format event-card__format--body">{event.formatLabel}</span>
                              {!isLecture && <h4 class="event-card__title">{event.title}</h4>}
                            </div>

                            {isDialogueEvent && (
                              <div class="event-card__cast">
                                {event.dialogueParticipants.map((participant) => (
                                  <span>{participant.name}</span>
                                ))}
                              </div>
                            )}

                            {!isDialogueEvent && !isSpecialEvent && event.speakerLabel && <p class="event-card__speaker">{event.speakerLabel}</p>}
                            {!isDialogueEvent && !isSpecialEvent && event.affiliation && <p class="event-card__affiliation">{event.affiliation}</p>}

                            {isLecture && event.speakerLectureLinks.length > 0 && (
                              <div class="event-card__speaker-links" aria-label={`Другие лекции спикера ${event.speakerLabel}`}>
                                <span>Ещё у лектора:</span>
                                {event.speakerLectureLinks.map((lecture) => (
                                  <a href={`#event-${lecture.slug}`} title={lecture.dateLabel}>{lecture.title}</a>
                                ))}
                              </div>
                            )}

                            {event.relatedEvent && (
                              <div class="event-card__related">
                                <p class="event-card__related-label">{event.relatedEvent.relationLabel}</p>
                                <a class="event-card__related-link" href={`#event-${event.relatedEvent.slug}`}>
                                  <strong>{event.relatedEvent.title}</strong>
                                  <span>{getRelatedMetaLine(event.relatedEvent)}</span>
                                  <span>{getRelatedSecondaryLine(event.relatedEvent)}</span>
                                </a>
                              </div>
                            )}

                            {event.kind === 'range' && (
                              <div class="event-card__range-info">
                                <span class="event-card__range-label">Период экспонирования</span>
                                <strong>{event.dateLabel}</strong>
                                <span class="event-card__range-detail">{getRangeVisitLabel(event, useScientificLibraryVisitSchedule)}</span>
                                {useScientificLibraryVisitSchedule && (
                                  <span class="event-card__range-detail">{SCIENTIFIC_LIBRARY_VISIT_SCHEDULE.sanitaryLabel}</span>
                                )}
                                <span class="event-card__range-detail">{event.venue} · {event.address}</span>
                                {useScientificLibraryVisitSchedule && (
                                  <a
                                    class="event-card__range-link"
                                    href={SCIENTIFIC_LIBRARY_VISIT_SCHEDULE.sourceUrl}
                                    target="_blank"
                                    rel="noreferrer"
                                  >
                                    {SCIENTIFIC_LIBRARY_VISIT_SCHEDULE.sourceLabel}
                                  </a>
                                )}
                              </div>
                            )}

                            <details class="event-card__summary-details">
                              <summary class="event-card__summary-toggle">
                                <span class="event-card__summary-text">{cardText}</span>
                                <span class="event-card__summary-hint" aria-hidden="true"></span>
                              </summary>
                              {cardExtraText && <p class="event-card__summary-extra">{cardExtraText}</p>}
                            </details>

                            <div class="event-card__meta">
                              <span>{event.venue}</span>
                              <span>{event.address}</span>
                              <span>{event.durationLabel}</span>
                            </div>
                          </div>

                          <aside class="event-card__actions">
                            {isSpecialEvent ? (
                              <div class="notice">Дата спектакля будет объявлена позже.</div>
                            ) : event.registrationUrl ? (
                              <a
                                class="button button--primary"
                                href={event.registrationUrl}
                                target="_blank"
                                rel="noreferrer"
                              >
                                Регистрация
                              </a>
                            ) : (
                              <div class="notice">Дата спектакля будет объявлена позже.</div>
                            )}

                            {!isSpecialEvent && event.calendarReady ? (
                              <details class="calendar-menu">
                                <summary class="button button--ghost">В календарь</summary>
                                <div class="calendar-panel">
                                  <a class="calendar-link" href={event.icsUrl}>ICS</a>
                                  <a
                                    class="calendar-link"
                                    href={event.googleCalendarUrl}
                                    target="_blank"
                                    rel="noreferrer"
                                  >
                                    Google
                                  </a>
                                </div>
                              </details>
                            ) : !isSpecialEvent ? (
                              <div class="notice">{event.calendarNote ?? 'Календарь появится позже.'}</div>
                            ) : null}
                          </aside>
                        </div>
                      </article>
                    );
                  })}
                </div>
              </section>
            ))}
          </div>
        </div>
      </section>

      <section class="section section--compact" id="announces">
        <div class="container footer-panels">
          <article class="footer-panel footer-panel--telegram">
            <div class="telegram-card">
              <div class="telegram-card__content">
                <span class="telegram-card__eyebrow">Канал анонсов</span>
                <h3>{TELEGRAM_CHANNEL_NAME}</h3>
                <p class="telegram-card__handle">{TELEGRAM_CHANNEL_HANDLE}</p>
                <p>В канале публикуем новые анонсы, изменения программы и короткие напоминания о событиях, чтобы важные обновления не потерялись в общей ленте.</p>
                <div class="footer-panel__actions telegram-card__actions">
                  <a class="button button--primary" href={TELEGRAM_ANNOUNCEMENT_URL} target="_blank" rel="noreferrer">
                    Открыть канал в Telegram
                  </a>
                </div>
              </div>

              <a
                class="telegram-card__qr"
                href={TELEGRAM_ANNOUNCEMENT_URL}
                target="_blank"
                rel="noreferrer"
                aria-label={`Открыть Telegram-канал ${TELEGRAM_CHANNEL_NAME}`}
              >
                <img
                  src={TELEGRAM_QR_CODE_URL}
                  alt={`QR-код для перехода в Telegram-канал ${TELEGRAM_CHANNEL_NAME}`}
                  width="250"
                  height="250"
                  loading="eager"
                  decoding="async"
                />
                <strong>Сканируйте с телефона</strong>
                <span>На десктопе QR открывает тот же канал без ручного поиска.</span>
              </a>
            </div>
          </article>

          <article class="footer-panel" id="press">
            <h3>Для СМИ</h3>
            <p>Официальный сайт просветительского фестиваля Российского общества Знание «80 историй о главном» к 80-летию Калининградской области.</p>
            <p>Для пресс-служб и редакций здесь должны быть базовые материалы без поиска по странице: положение фестиваля, официальный пресс-контакт и ссылка на актуальную программу.</p>
            <div class="footer-panel__actions">
              <a class="button button--ghost" href={FESTIVAL_REGULATION_URL} target="_blank" rel="noreferrer">
                Положение фестиваля PDF
              </a>
              <a class="button button--primary" href={`mailto:${PRESS_EMAIL}`}>
                {PRESS_EMAIL}
              </a>
            </div>
          </article>
        </div>
      </section>
    </main>
  </div>

  <script is:inline>
    const speakerStrip = document.querySelector('.speaker-strip');

    const shuffleInPlace = (items) => {
      for (let index = items.length - 1; index > 0; index -= 1) {
        const randomIndex = Math.floor(Math.random() * (index + 1));
        [items[index], items[randomIndex]] = [items[randomIndex], items[index]];
      }
      return items;
    };

    const pickWeightedSpeakers = (pool, count) => {
      const available = [...pool];
      const selection = [];

      while (selection.length < count && available.length) {
        const totalWeight = available.reduce((sum, speaker) => sum + Math.max(Number(speaker.weight) || 1, 0.1), 0);
        let threshold = Math.random() * totalWeight;
        let selectedIndex = available.length - 1;

        for (let index = 0; index < available.length; index += 1) {
          threshold -= Math.max(Number(available[index].weight) || 1, 0.1);
          if (threshold <= 0) {
            selectedIndex = index;
            break;
          }
        }

        selection.push(available.splice(selectedIndex, 1)[0]);
      }

      return selection;
    };

    const buildSpeakerEntry = (speaker, index) => {
      const entry = document.createElement('a');
      entry.className = `speaker-entry speaker-entry--${index + 1}`;
      entry.href = `#${speaker.anchor}`;

      const meta = document.createElement('div');
      meta.className = 'speaker-entry__meta';

      const title = document.createElement('strong');
      title.textContent = speaker.name;
      meta.appendChild(title);

      if (speaker.affiliation) {
        const caption = document.createElement('span');
        caption.textContent = speaker.affiliation.replace(/\s+/g, ' ').trim();
        meta.appendChild(caption);
      }

      const media = document.createElement('div');
      media.className = 'speaker-entry__media';

      const image = document.createElement('img');
      image.className = 'speaker-entry__portrait';
      image.src = speaker.image;
      image.alt = speaker.name;
      image.loading = 'eager';
      image.decoding = 'async';

      if (speaker.style) {
        image.style.cssText = speaker.style;
      }

      media.appendChild(image);
      entry.append(meta, media);

      return entry;
    };

    const preloadSpeakerImages = (speakers) => Promise.all(
      speakers.map((speaker) => new Promise((resolve) => {
        if (!speaker.image) {
          resolve();
          return;
        }

        const image = new Image();
        const finish = () => {
          image.onload = null;
          image.onerror = null;
          window.clearTimeout(timeoutId);
          resolve();
        };
        const timeoutId = window.setTimeout(finish, 2500);
        image.onload = finish;
        image.onerror = finish;
        image.src = speaker.image;

        if (image.complete) {
          finish();
        }
      })),
    );

    if (speakerStrip?.dataset.speakers) {
      (async () => {
        try {
          const speakerPool = JSON.parse(speakerStrip.dataset.speakers);
          const visibleCount = Number.parseInt(speakerStrip.dataset.visibleCount || '', 10)
            || speakerStrip.children.length
            || 8;
          const selectedSpeakers = shuffleInPlace(
            pickWeightedSpeakers(speakerPool, Math.min(visibleCount, speakerPool.length)),
          );

          await preloadSpeakerImages(selectedSpeakers);

          const fragment = document.createDocumentFragment();
          selectedSpeakers.forEach((speaker, index) => {
            fragment.appendChild(buildSpeakerEntry(speaker, index));
          });

          speakerStrip.replaceChildren(fragment);
        } catch (error) {
          console.error('Speaker showcase randomizer failed', error);
        }
      })();
    }

    const cycleNodes = Array.from(document.querySelectorAll('[data-portrait-frames]'));
    const timers = new Map();

    const startCycle = (node) => {
      if (timers.has(node)) return;

      const frames = (node.dataset.portraitFrames || '').split('|').filter(Boolean);
      const images = Array.from(node.querySelectorAll('.portrait-cycle__image'));

      if (frames.length < 2 || images.length < 2) {
        return;
      }

      let visibleIndex = 0;
      let frameIndex = 1;

      const tick = () => {
        const nextVisibleIndex = visibleIndex === 0 ? 1 : 0;
        const current = images[visibleIndex];
        const next = images[nextVisibleIndex];

        next.src = frames[frameIndex];
        window.requestAnimationFrame(() => {
          next.classList.add('is-active');
          current.classList.remove('is-active');
        });

        visibleIndex = nextVisibleIndex;
        frameIndex = (frameIndex + 1) % frames.length;
      };

      const timer = window.setInterval(tick, 5200);
      timers.set(node, timer);
    };

    const stopCycle = (node) => {
      const timer = timers.get(node);
      if (timer) {
        window.clearInterval(timer);
        timers.delete(node);
      }
    };

    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      const observer = new IntersectionObserver((entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            startCycle(entry.target);
          } else {
            stopCycle(entry.target);
          }
        }
      }, { threshold: 0.45 });

      cycleNodes.forEach((node) => observer.observe(node));
    }
  </script>
</Layout>

---
import Layout from '../layouts/Layout.astro';
import {
  getFestivalEvents,
  getMonthGroups,
  getOpenDialogues,
  getSpeakerShowcase,
} from '../lib/festival';

const events = getFestivalEvents();
const monthGroups = getMonthGroups(events);
const speakerShowcase = getSpeakerShowcase(events);
const openDialogues = getOpenDialogues(events).slice(0, 5);
const nextEvent = events[0];

const MONTH_SHORT: Record<string, string> = {
  января: 'янв',
  февраля: 'фев',
  марта: 'мар',
  апреля: 'апр',
  мая: 'май',
  июня: 'июн',
  июля: 'июл',
};

const WEEKDAY_SHORT: Record<string, string> = {
  понедельник: 'пн',
  вторник: 'вт',
  среда: 'ср',
  четверг: 'чт',
  пятница: 'пт',
  суббота: 'сб',
  воскресенье: 'вс',
};

function getDateParts(dateLabel: string) {
  const match = dateLabel.match(/(\d{1,2})\s+([а-я]+)\s+2026(?:\s+\(([^)]+)\))?/i);
  if (!match) {
    return {
      day: '??',
      month: 'скоро',
      weekday: '',
    };
  }

  return {
    day: match[1].padStart(2, '0'),
    month: MONTH_SHORT[match[2].toLowerCase()] ?? match[2].slice(0, 3),
    weekday: WEEKDAY_SHORT[(match[3] ?? '').toLowerCase()] ?? '',
  };
}

function getCardText(event: { whyGo: string; summary: string }) {
  return event.whyGo || event.summary;
}

function getPortraitFrames(images: string[]) {
  return images.join('|');
}

function getSpeakerCaption(value: string) {
  if (!value) {
    return '';
  }

  const base = value.split(/[,.]/)[0]?.trim() ?? value.trim();
  return base.length > 34 ? `${base.slice(0, 31).trimEnd()}...` : base;
}
---

<Layout
  title="80 историй о главном | Прототип главной страницы"
  description="Афишный прототип фестиваля: image-first программа, плотный обзор длинной ленты и крупные портреты спикеров."
>
  <div class="page">
    <header class="site-header">
      <div class="container site-header__row">
        <a class="site-header__logo" href="#top" aria-label="Российское общество Знание">
          <img src="/shared-assets/logo-znanie.svg" alt="Логотип Российского общества Знание" width="647" height="150" />
        </a>

        <nav class="site-header__nav" aria-label="Быстрые разделы">
          <a href="#speakers">Спикеры</a>
          <a href="#program">Программа</a>
          <a href="#dialogues">Диалоги</a>
          <a href="#press">СМИ</a>
        </nav>
      </div>
    </header>

    <main id="top">
      <section class="hero">
        <div class="container">
          <div class="hero__shell">
            <div class="hero__copy">
              <p class="eyebrow">Просветительский фестиваль Российского общества Знание</p>
              <p class="hero__kicker">К 80-летию Калининградской области</p>
              <h1>80 историй о главном</h1>
              <p class="hero__lead">
                В десктопе программа должна ощущаться как живая афиша, а не как длинный корпоративный реестр.
                Поэтому главный вход здесь через изображение, дату, человека и одно сильное обещание события.
              </p>

              <div class="hero__meta" aria-label="Ключевые параметры фестиваля">
                <span>Калининград</span>
                <span>28 марта - 19 июля 2026</span>
                <span>{events.length} событий в текущей сборке</span>
              </div>

              <div class="hero__actions">
                <a class="button button--primary" href="#program">Смотреть программу</a>
                <a class="button button--ghost" href="#announces">Подписаться на анонсы</a>
              </div>

              <p class="hero__note">
                Приоритетный сценарий: быстро выбрать несколько событий подряд и не потерять их.
              </p>
            </div>

            <aside class="hero__aside" aria-label="Ближайшее событие и визуальная атмосфера">
              <article class="hero-ticket">
                <p class="hero-ticket__eyebrow">Ближайшее событие</p>
                <h2>{nextEvent.title}</h2>
                <div class="hero-ticket__meta">
                  <span>{nextEvent.dateLabel}</span>
                  <span>{nextEvent.timeLabel}</span>
                  <span>{nextEvent.venue}</span>
                </div>
                <a class="button button--light" href={`#event-${nextEvent.slug}`}>К событию</a>
              </article>

              <div class="hero-mosaic" aria-hidden="true">
                <figure class="hero-mosaic__item hero-mosaic__item--large">
                  <img src={nextEvent.image} alt="" loading="eager" />
                </figure>
                <figure class="hero-mosaic__item hero-mosaic__item--tall">
                  <img src="/shared-assets/hero-added-04.webp" alt="" loading="lazy" />
                </figure>
                <figure class="hero-mosaic__item hero-mosaic__item--wide">
                  <img src="/shared-assets/hero-added-09.webp" alt="" loading="lazy" />
                </figure>
              </div>
            </aside>
          </div>
        </div>
      </section>

      <section class="section speaker-section" id="speakers">
        <div class="container">
          <div class="speaker-poster">
            <div class="speaker-poster__masthead">
              <div class="speaker-poster__topline">
                <p class="speaker-poster__eyebrow">Люди фестиваля</p>
                <p class="speaker-poster__stamp">Калининград / 2026 / 80 историй о главном</p>
              </div>

              <h2>
                <span>ГОЛОСА</span>
                <span>ФЕСТИВАЛЯ</span>
              </h2>

              <p class="speaker-poster__note">
                Крупные лица, резкий кроп, без карточного воздуха.
              </p>
            </div>

            <div class="speaker-strip">
              {speakerShowcase.map((speaker, index) => (
                <a class={`speaker-entry speaker-entry--${index + 1}`} href={`#${speaker.anchor}`}>
                  <div class="speaker-entry__meta">
                    <strong>{speaker.name}</strong>
                    {speaker.affiliation && <span>{getSpeakerCaption(speaker.affiliation)}</span>}
                  </div>

                  <div class="speaker-entry__media portrait-cycle" data-portrait-frames={getPortraitFrames(speaker.images)}>
                    <img
                      class="portrait-cycle__image is-active"
                      src={speaker.images[0]}
                      alt={speaker.name}
                      loading="lazy"
                    />
                    {speaker.images.length > 1 && (
                      <img
                        class="portrait-cycle__image"
                        src={speaker.images[1]}
                        alt={speaker.name}
                        loading="lazy"
                        aria-hidden="true"
                      />
                    )}
                  </div>
                </a>
              ))}
            </div>
          </div>
        </div>
      </section>

      <section class="section section--compact" id="dialogues">
        <div class="container">
          <div class="section__header section__header--split">
            <div>
              <p class="section__eyebrow">Открытые диалоги</p>
              <h2>Их нужно выделять как отдельную драматургию фестиваля, а не как ещё один тип карточки</h2>
            </div>
            <p class="section__text">
              Здесь оставляю короткий ряд афишных анонсов: многоголосие, столкновение точек зрения и ощущение публичного разговора.
            </p>
          </div>

          <div class="dialogue-strip">
            {openDialogues.map((event) => (
              <a class="dialogue-card" href={`#event-${event.slug}`}>
                <span class="dialogue-card__meta">{event.dateLabel}</span>
                <strong>{event.title}</strong>
                <span>{event.venue}</span>
              </a>
            ))}
          </div>
        </div>
      </section>

      <section class="section section--program" id="program">
        <div class="container">
          <div class="section__header section__header--split">
            <div>
              <p class="section__eyebrow">Программа</p>
              <h2>Вся лента должна сканироваться быстро: дата, картинка, спикер и минимум ключевой информации</h2>
            </div>
            <p class="section__text">
              На десктопе перестраиваю список в плотный image-first ритм. Длинные абзацы убраны из первого экрана карточки,
              а на первый план выходят дата, афиша события и заметный человек.
            </p>
          </div>

          <div class="month-nav-wrap">
            <nav class="month-nav" aria-label="Навигация по месяцам">
              {monthGroups.map((group) => (
                <a href={`#month-${group.anchor}`}>{group.label}</a>
              ))}
            </nav>
          </div>

          <div class="program">
            {monthGroups.map((group) => (
              <section class="month-block" id={`month-${group.anchor}`}>
                <header class="month-block__header">
                  <div>
                    <p class="month-block__eyebrow">2026</p>
                    <h3>{group.label}</h3>
                  </div>
                  <span class="month-block__count">{group.events.length} событий</span>
                </header>

                <div class="event-list">
                  {group.events.map((event) => {
                    const dateParts = getDateParts(event.dateLabel);
                    const portraitFrames = getPortraitFrames(event.speakerImages);

                    return (
                      <article class={`event-card ${event.speakerImages.length ? 'event-card--with-speaker' : ''}`} id={`event-${event.slug}`}>
                        <div class="event-card__date">
                          <span class="event-card__day">{dateParts.day}</span>
                          <span class="event-card__month">{dateParts.month}</span>
                          {dateParts.weekday && <span class="event-card__weekday">{dateParts.weekday}</span>}
                          <span class="event-card__time">{event.timeLabel}</span>
                        </div>

                        <div class="event-card__main">
                          <div class="event-card__stage">
                            <div class="event-card__visual">
                              <img class="event-card__poster" src={event.image} alt={`Афиша: ${event.title}`} loading="lazy" />
                              <div class="event-card__overlay"></div>
                              <div class="event-card__headline">
                                <span class="event-card__format">{event.formatLabel}</span>
                                <h4>{event.title}</h4>
                              </div>
                            </div>

                            {event.speakerImages.length > 0 && (
                              <div class="event-card__portrait portrait-cycle" data-portrait-frames={portraitFrames}>
                                <img
                                  class="portrait-cycle__image is-active"
                                  src={event.speakerImages[0]}
                                  alt={event.speakerLabel}
                                  loading="lazy"
                                />
                                {event.speakerImages.length > 1 && (
                                  <img
                                    class="portrait-cycle__image"
                                    src={event.speakerImages[1]}
                                    alt={event.speakerLabel}
                                    loading="lazy"
                                    aria-hidden="true"
                                  />
                                )}
                              </div>
                            )}
                          </div>

                          <div class="event-card__body">
                            {event.speakerLabel && <p class="event-card__speaker">{event.speakerLabel}</p>}
                            {event.affiliation && <p class="event-card__affiliation">{event.affiliation}</p>}

                            <p class="event-card__summary">{getCardText(event)}</p>

                            <div class="event-card__meta">
                              <span>{event.venue}</span>
                              <span>{event.address}</span>
                              <span>{event.durationLabel}</span>
                            </div>
                          </div>

                          <aside class="event-card__actions">
                            {event.registrationUrl ? (
                              <a
                                class="button button--primary"
                                href={event.registrationUrl}
                                target="_blank"
                                rel="noreferrer"
                              >
                                Регистрация
                              </a>
                            ) : (
                              <div class="notice">Дата спектакля будет объявлена позже.</div>
                            )}

                            {event.calendarReady ? (
                              <details class="calendar-menu">
                                <summary class="button button--ghost">В календарь</summary>
                                <div class="calendar-panel">
                                  <a class="calendar-link" href={event.icsUrl}>ICS</a>
                                  <a
                                    class="calendar-link"
                                    href={event.googleCalendarUrl}
                                    target="_blank"
                                    rel="noreferrer"
                                  >
                                    Google
                                  </a>
                                </div>
                              </details>
                            ) : (
                              <div class="notice">{event.calendarNote ?? 'Календарь появится позже.'}</div>
                            )}
                          </aside>
                        </div>
                      </article>
                    );
                  })}
                </div>
              </section>
            ))}
          </div>
        </div>
      </section>

      <section class="section section--compact" id="announces">
        <div class="container footer-panels">
          <article class="footer-panel">
            <h3>Анонсы фестиваля</h3>
            <p>Дальше сюда можно дать Telegram и короткий QR, но сама страница уже должна продавать выбор нескольких событий без дополнительного объяснения.</p>
            <div class="footer-panel__actions">
              <a class="button button--primary" href="https://t.me/" target="_blank" rel="noreferrer">
                Перейти в Telegram
              </a>
            </div>
          </article>

          <article class="footer-panel" id="press">
            <h3>Для СМИ</h3>
            <p>Пресс-контакт, фотобанк, PDF-положение, логотипы и официальное описание фестиваля должны жить в отдельном коротком разделе, а не смешиваться с программой.</p>
          </article>
        </div>
      </section>
    </main>
  </div>

  <script is:inline>
    const cycleNodes = Array.from(document.querySelectorAll('[data-portrait-frames]'));
    const timers = new Map();

    const startCycle = (node) => {
      if (timers.has(node)) return;

      const frames = (node.dataset.portraitFrames || '').split('|').filter(Boolean);
      const images = Array.from(node.querySelectorAll('.portrait-cycle__image'));

      if (frames.length < 2 || images.length < 2) {
        return;
      }

      let visibleIndex = 0;
      let frameIndex = 1;

      const tick = () => {
        const nextVisibleIndex = visibleIndex === 0 ? 1 : 0;
        const current = images[visibleIndex];
        const next = images[nextVisibleIndex];

        next.src = frames[frameIndex];
        window.requestAnimationFrame(() => {
          next.classList.add('is-active');
          current.classList.remove('is-active');
        });

        visibleIndex = nextVisibleIndex;
        frameIndex = (frameIndex + 1) % frames.length;
      };

      const timer = window.setInterval(tick, 5200);
      timers.set(node, timer);
    };

    const stopCycle = (node) => {
      const timer = timers.get(node);
      if (timer) {
        window.clearInterval(timer);
        timers.delete(node);
      }
    };

    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      const observer = new IntersectionObserver((entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            startCycle(entry.target);
          } else {
            stopCycle(entry.target);
          }
        }
      }, { threshold: 0.45 });

      cycleNodes.forEach((node) => observer.observe(node));
    }
  </script>
</Layout>

---
import Layout from '../layouts/Layout.astro';
import {
  getFestivalEvents,
  getHookQuotes,
  getMonthGroups,
  getOpenDialogues,
  getSpeakerShowcase,
} from '../lib/festival';

const events = getFestivalEvents();
const monthGroups = getMonthGroups(events);
const speakerShowcase = getSpeakerShowcase(events);
const hooks = getHookQuotes(events);
const openDialogues = getOpenDialogues(events);
const nextEvent = events[0];
---

<Layout
  title="80 историй о главном | Прототип главной страницы"
  description="Прототип фестивального лендинга: image-first карточки событий, крупный спикер, регистрация и календарь прямо в ленте."
>
  <div class="page">
    <header class="site-header">
      <div class="container site-header__row">
        <a class="site-header__logo" href="#top" aria-label="Российское общество Знание">
          <img src="/shared-assets/logo-znanie.svg" alt="Логотип Российского общества Знание" width="647" height="150" />
        </a>

        <nav class="site-header__nav" aria-label="Быстрые разделы">
          <a href="#program">Программа</a>
          <a href="#dialogues">Открытые диалоги</a>
          <a href="#formats">Форматы</a>
          <a href="#press">Пресса</a>
        </nav>
      </div>
    </header>

    <main id="top">
      <section class="hero">
        <div class="container">
          <div class="hero__shell">
            <div class="hero__grid">
              <div>
                <p class="eyebrow">Просветительский фестиваль Российского общества Знание</p>
                <h1>80 историй о главном</h1>
                <p class="hero__lead">
                  Обновлённый прототип уже строится в логике фестиваля: картинка и человек работают как главный вход,
                  а список событий остаётся открытым, плотным и удобным для выбора нескольких мероприятий подряд.
                </p>

                <div class="hero__badges" aria-label="Ключевые метки фестиваля">
                  <span>Калининград</span>
                  <span>28 марта — 19 июля 2026</span>
                  <span>Регистрация сразу на все события</span>
                </div>

                <div class="hero__actions">
                  <a class="button button--primary" href="#program">Смотреть программу</a>
                  <a class="button button--light" href="#announces">Подписаться на анонсы</a>
                </div>
              </div>

              <aside class="hero__aside" aria-label="Ближайшее событие">
                <p class="panel-label">Ближайшее событие</p>
                <div class="next-event-card">
                  <h2>{nextEvent.title}</h2>
                  <div class="next-event-card__meta">
                    <span>{nextEvent.dateLabel}</span>
                    <span>{nextEvent.timeLabel}</span>
                    <span>{nextEvent.venue}, {nextEvent.address}</span>
                    <span>{nextEvent.formatLabel}</span>
                  </div>
                  <div class="hero__actions hero__actions--compact">
                    <a class="button button--primary" href={`#event-${nextEvent.slug}`}>К событию</a>
                  </div>
                </div>
              </aside>
            </div>
          </div>
        </div>
      </section>

      <section class="section section--compact">
        <div class="container">
          <div class="section__header">
            <p class="section__eyebrow">Hooks</p>
            <h2>Сильные фразы должны подталкивать к просмотру программы</h2>
          </div>

          <div class="hooks">
            {hooks.map((item) => (
              <article class="hook-card">
                <blockquote>“{item.quote}”</blockquote>
                <a class="hook-card__link" href={`#${item.anchor}`}>Перейти к событию</a>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="section section--compact" id="speakers">
        <div class="container">
          <div class="section__header">
            <p class="section__eyebrow">Спикеры</p>
            <h2>Полоса спикеров должна быть уже, живее и визуально дороже</h2>
            <p class="section__text">
              Здесь я оставляю идею вертикальных slats, но делаю людей крупнее и читаемее. По клику зритель попадает сразу к событию.
            </p>
          </div>

          <div class="speaker-strip">
            {speakerShowcase.map((speaker) => (
              <a class="speaker-card" href={`#${speaker.anchor}`}>
                <div class="speaker-card__content">
                  <strong>{speaker.name}</strong>
                  {speaker.affiliation && <span>{speaker.affiliation}</span>}
                </div>
                <img src={speaker.image} alt={speaker.name} loading="lazy" />
              </a>
            ))}
          </div>
        </div>
      </section>

      <section class="section section--compact" id="dialogues">
        <div class="container">
          <div class="section__header">
            <p class="section__eyebrow">Открытые диалоги</p>
            <h2>Отдельный формат, который нужно подсветить как особую ценность фестиваля</h2>
            <p class="section__text">
              Это не лекции и не должны выглядеть как обычные лекции. Здесь важны многоголосие, столкновение взглядов и общая энергия разговора.
            </p>
          </div>

          <div class="dialogue-strip">
            {openDialogues.map((event) => (
              <a class="dialogue-card" href={`#event-${event.slug}`}>
                <span class="dialogue-card__meta">{event.dateLabel}</span>
                <strong>{event.title}</strong>
                <span>{event.venue}</span>
              </a>
            ))}
          </div>
        </div>
      </section>

      <section class="section" id="program">
        <div class="container">
          <div class="section__header">
            <p class="section__eyebrow">Программа</p>
            <h2>Все события открыты сразу, без лишних переходов и без скрытой информации</h2>
            <p class="section__text">
              На этом этапе я показываю полную открытую ленту. На десктопе карточки становятся плотнее, image-first и строятся вокруг визуала и спикера,
              а не вокруг большого текстового блока.
            </p>
          </div>

          <div class="month-nav-wrap">
            <nav class="month-nav" aria-label="Навигация по месяцам">
              {monthGroups.map((group) => (
                <a href={`#month-${group.anchor}`}>{group.label}</a>
              ))}
            </nav>
          </div>

          <div class="program">
            {monthGroups.map((group) => (
              <section class="month-block" id={`month-${group.anchor}`}>
                <header class="month-block__header">
                  <h3>{group.label}</h3>
                  <span class="month-block__count">{group.events.length} событий</span>
                </header>

                <div class="event-list">
                  {group.events.map((event) => (
                    <article class="event-card" id={`event-${event.slug}`}>
                      <div class="event-card__visual">
                        {event.image ? (
                          <img class="event-card__poster" src={event.image} alt={`Иллюстрация: ${event.title}`} loading="lazy" />
                        ) : (
                          <div class="event-card__placeholder" aria-hidden="true">
                            <span>{event.formatLabel}</span>
                            <strong>Визуал события готовится</strong>
                          </div>
                        )}

                        <div class="event-card__overlay">
                          <div class="event-card__overlay-row">
                            <span class="badge badge--light">{event.formatLabel}</span>
                            <span class="meta-chip meta-chip--light">{event.dateLabel}</span>
                          </div>
                          <h4>{event.title}</h4>
                        </div>

                        {event.speakerImages.length > 0 && (
                          <div
                            class="event-card__speaker-wrap"
                            data-rotating-images={event.speakerImages.join(',')}
                          >
                            <img
                              class="event-card__speaker"
                              src={event.speakerImages[0]}
                              alt={event.speakerLabel}
                              loading="lazy"
                            />
                          </div>
                        )}
                      </div>

                      <div class="event-card__content">
                        <div class="event-card__meta-grid">
                          <span class="meta-chip">{event.timeLabel}</span>
                          <span class="meta-chip">{event.durationLabel}</span>
                          <span class="meta-chip">{event.venue}</span>
                          <span class="meta-chip">{event.address}</span>
                        </div>

                        {event.speakerLabel && (
                          <div class="event-card__speaker-meta">
                            <strong>{event.speakerLabel}</strong>
                            {event.affiliation && <span>{event.affiliation}</span>}
                          </div>
                        )}

                        {event.whyGo && <p class="event-card__why">{event.whyGo}</p>}
                        <p class="event-card__summary">{event.summary}</p>
                      </div>

                      <aside class="event-card__actions">
                        {event.registrationUrl ? (
                          <a
                            class="button button--primary"
                            href={event.registrationUrl}
                            target="_blank"
                            rel="noreferrer"
                          >
                            Регистрация
                          </a>
                        ) : (
                          <div class="notice">Информация о спектакле будет объявлена на открытии фестиваля.</div>
                        )}

                        {event.calendarReady ? (
                          <details class="calendar-menu">
                            <summary class="button button--dark">В календарь</summary>
                            <div class="calendar-panel">
                              <a
                                class="calendar-link"
                                href={event.googleCalendarUrl}
                                target="_blank"
                                rel="noreferrer"
                              >
                                Google Calendar
                              </a>
                              <a class="calendar-link" href={event.icsUrl}>
                                ICS / Apple Calendar
                              </a>
                            </div>
                          </details>
                        ) : (
                          <div class="notice">{event.calendarNote ?? 'Календарь появится позже.'}</div>
                        )}
                      </aside>
                    </article>
                  ))}
                </div>
              </section>
            ))}
          </div>
        </div>
      </section>

      <section class="section section--compact" id="formats">
        <div class="container">
          <div class="section__header">
            <p class="section__eyebrow">Форматы</p>
            <h2>Нужно быстро объяснить, что у фестиваля несколько разных режимов посещения</h2>
          </div>

          <div class="formats-grid">
            <article class="format-card">
              <h3>Лекция</h3>
              <p>В среднем 1 час, вопросы из зала, модератор и ясный маршрут от любопытства к решению записаться.</p>
            </article>
            <article class="format-card">
              <h3>Открытый диалог</h3>
              <p>Несколько участников, разные позиции и тема, которую хочется обсуждать, а не только слушать.</p>
            </article>
            <article class="format-card">
              <h3>Выставки и спектакль</h3>
              <p>Выставки показываются как длительные периоды, а иммерсивный спектакль живёт как особый анонс с отдельной механикой входа.</p>
            </article>
          </div>
        </div>
      </section>

      <section class="section" id="announces">
        <div class="container footer-panels">
          <article class="footer-panel">
            <h3>Анонсы фестиваля</h3>
            <p>В desktop-версии здесь позже можно дать и ссылку, и QR-код. В мобильной оставить одну быструю кнопку.</p>
            <div class="footer-panel__actions">
              <a class="button button--primary" href="https://t.me/" target="_blank" rel="noreferrer">
                Перейти в Telegram
              </a>
            </div>
          </article>

          <article class="footer-panel" id="press">
            <h3>Для СМИ</h3>
            <p>Отдельная короткая страница: пресс-контакт, фотобанк, PDF-положение, логотипы и краткое официальное описание фестиваля.</p>
          </article>

          <article class="footer-panel">
            <h3>Что уже проверяем этим прототипом</h3>
            <p>Плотность ленты, работу реальных картинок, роль крупного спикера и то, помогает ли image-first карточка быстрее выбрать событие.</p>
          </article>
        </div>
      </section>

      <div class="container footer-note">
        Прототип остаётся landing-first: основной пользовательский сценарий живёт прямо на главной, а не уводится в отдельные страницы.
      </div>
    </main>
  </div>

  <script is:inline>
    const rotatingNodes = Array.from(document.querySelectorAll('[data-rotating-images]'));
    const timers = new Map();
    const observer = new IntersectionObserver((entries) => {
      for (const entry of entries) {
        const node = entry.target;
        const img = node.querySelector('img');
        const images = (node.dataset.rotatingImages || '').split(',').filter(Boolean);

        if (!img || images.length < 2) {
          continue;
        }

        if (entry.isIntersecting) {
          if (timers.has(node)) continue;
          let index = 0;
          const timer = window.setInterval(() => {
            index = (index + 1) % images.length;
            img.src = images[index];
          }, 4200);
          timers.set(node, timer);
        } else if (timers.has(node)) {
          window.clearInterval(timers.get(node));
          timers.delete(node);
        }
      }
    }, { threshold: 0.55 });

    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      rotatingNodes.forEach((node) => observer.observe(node));
    }
  </script>
</Layout>

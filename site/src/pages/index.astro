function getDateParts(dateLabel: string) {
  const match = dateLabel.match(/(\d{1,2})\s+([а-я]+)\s+2026(?:\s+\(([^)]+)\))?/i);
  if (!match) {
    return {
      day: '??',
      month: 'скоро',
      weekday: '',
    };
  }

  return {
    day: match[1],
    month: match[2].toLowerCase(),
    weekday: WEEKDAY_SHORT[(match[3] ?? '').toLowerCase()] ?? '',
  };
}

function getRangeDateParts(dateLabel: string) {
  const match = dateLabel.match(/(?:с\s*)?(\d{1,2})\s+([а-я]+)(?:\s+\d{4})?\s*(?:-|—|–|по)\s*(\d{1,2})\s+([а-я]+)\s+(\d{4})/i);
  if (!match) {
    return null;
  }

  return {
    startDay: match[1],
    startMonth: match[2].toLowerCase(),
    endDay: match[3],
    endMonth: match[4].toLowerCase(),
  };
}

function getCardText(event: { whyGo: string; summary: string }) {
  return event.summary || event.whyGo;
}

function getCardExtraText(event: { whyGo: string; summary: string }) {
  if (!event.whyGo) {
    return '';
  }

  return event.whyGo !== event.summary ? event.whyGo : '';
}

function shouldShowQuestionBlock(event: { questions: string[] }) {
  return event.questions.length >= 3;
}

function hasExpandableSummary(event: { whyGo: string; summary: string; questions: string[] }) {
  return Boolean(getCardExtraText(event) || shouldShowQuestionBlock(event));
}

function getRelatedMetaLine(relatedEvent: RelatedEventCard) {
  const parts = [relatedEvent.formatLabel, relatedEvent.dateLabel];

  if (relatedEvent.kind !== 'range' && !relatedEvent.timeLabel.includes('будет объявлено')) {
    parts.push(relatedEvent.timeLabel);
  }

  return parts.filter(Boolean).join(' · ');
}

function getRelatedSecondaryLine(relatedEvent: RelatedEventCard) {
  const parts = relatedEvent.kind === 'range'
    ? [relatedEvent.venue, relatedEvent.address]
    : [relatedEvent.speakerLabel, relatedEvent.venue];

  return parts.filter(Boolean).join(' · ');
}


function getLectureTitleClass(title: string) {
  const length = title.trim().length;

  if (length >= 88) {
    return 'event-card__visual-title event-card__visual-title--xxlong';
  }

  if (length >= 64) {
    return 'event-card__visual-title event-card__visual-title--xlong';
  }

  if (length >= 46) {
    return 'event-card__visual-title event-card__visual-title--long';
  }

  return 'event-card__visual-title';
}

function getPortraitFrames(name: string, images: string[], isLecture = false) {
  return images
    .map((image) => getEventPortraitImage(name, image, isLecture))
    .join('|');
}

function getEventPortraitImages(name: string, images: string[], isLecture = false) {
  return images.map((image) => getEventPortraitImage(name, image, isLecture));
}

function getSpeakerCaption(value: string) {
  if (!value) {
    return '';
  }

  return value.replace(/\s+/g, ' ').trim();
}

function stripWeekday(value: string) {
  return value.replace(/\s+\([^)]+\)/g, '').trim();
}

function getFestivalPeriodLabel(items: typeof events) {
  const dated = items.filter((event) => event.kind !== 'special' && event.isoStart);
  if (!dated.length) {
    return 'Даты скоро появятся';
  }

  const first = dated[0];
  const last = dated[dated.length - 1];
  return `${stripWeekday(first.dateLabel)} - ${stripWeekday(last.dateLabel)}`;
}

const festivalPeriodLabel = getFestivalPeriodLabel(events);
type PortraitSliceBounds = {
  y: number;
  visibleLeft: number;
  visibleRight: number;
  coverage: number;
};
const portraitBoundsMap = portraitBounds as Record<string, {
  width: number;
  height: number;
  visibleLeft: number;
  visibleTop: number;
  visibleRight: number;
  visibleBottom: number;
  slices?: Partial<Record<'head' | 'shoulder' | 'chest' | 'waist', PortraitSliceBounds>>;
}>;

function joinStyleFragments(...parts: Array<string | undefined>) {
  return parts
    .map((part) => part?.trim())
    .filter(Boolean)
    .join(' ');
}

function clampMetric(value: number, min: number, max: number) {
  return Math.max(min, Math.min(max, value));
}

function getPortraitBounds(path: string) {
  return portraitBoundsMap[path];
}

function getHeroPortraitStyle(name: string) {
  return HERO_PORTRAIT_STYLE_OVERRIDES.find((entry) => name.includes(entry.match))?.style;
}

function getHeroSceneOverride(name: string) {
  return HERO_SCENE_STYLE_OVERRIDES.find((entry) => name.includes(entry.match))?.style;
}

function getHeroSceneStyle(imagePath: string) {
  const bounds = getPortraitBounds(imagePath);
  if (!bounds) {
    return '';
  }

  const ratio = bounds.width / bounds.height;
  const visibleWidth = bounds.visibleRight - bounds.visibleLeft;
  const headSlice = bounds.slices?.head;
  const shoulderSlice = bounds.slices?.shoulder;
  const chestSlice = bounds.slices?.chest;
  const waistSlice = bounds.slices?.waist;
  const headLeft = headSlice?.visibleLeft ?? Math.min(bounds.visibleLeft + visibleWidth * 0.32, 0.6);
  const upperRight = Math.max(
    headSlice?.visibleRight ?? bounds.visibleRight,
    shoulderSlice?.visibleRight ?? bounds.visibleRight,
  );
  const upperCoverage = Math.max(
    headSlice?.coverage ?? visibleWidth * 0.56,
    shoulderSlice?.coverage ?? visibleWidth * 0.62,
  );
  const tallBias = Math.max(0, 0.92 - Math.min(ratio, 0.92));
  const waistCoverage = waistSlice?.coverage ?? visibleWidth * 0.72;
  const chestCoverage = chestSlice?.coverage ?? visibleWidth * 0.62;
  const shoulderCoverage = shoulderSlice?.coverage ?? visibleWidth * 0.58;
  const upperIntrusion = Math.max(0, upperRight - 0.62);
  const visualCenter = (bounds.visibleLeft + bounds.visibleRight) / 2;
  const quoteStart = clampMetric(
    8.15 + upperIntrusion * 19 + tallBias * 1.05 + Math.max(0, waistCoverage - 0.68) * 4.1
    + Math.max(0, visualCenter - 0.5) * 10,
    8.1,
    11.5,
  );
  const quoteWidth = clampMetric(
    28.8 - upperIntrusion * 22 - tallBias * 3.2 - Math.max(0, waistCoverage - 0.68) * 5.4
    - Math.max(0, visualCenter - 0.5) * 7
    + (0.82 - Math.min(visibleWidth, 0.98)) * 2.2,
    20.8,
    29.4,
  );
  const portraitHeadroom = clampMetric(1.7 + tallBias * 8.8, 1.6, 4.8);
  const portraitDrop = clampMetric(2.2 + tallBias * 10.5 + upperIntrusion * 10, 2.1, 7.2);
  const mobilePortraitHeadroom = clampMetric(0.55 + tallBias * 4.8, 0.55, 2.2);
  const mobileCopyWidth = clampMetric(62 - Math.max(0, ratio - 0.72) * 30, 49, 61);
  const mobilePortraitWidth = clampMetric(
    56 + Math.max(0, ratio - 0.72) * 20 + Math.max(0, 0.72 - ratio) * 4,
    56,
    68.5,
  );
  const mobilePortraitScale = clampMetric(
    1.08 + Math.max(0, 0.72 - ratio) * 0.55 + Math.max(0, ratio - 0.92) * 0.24,
    1.08,
    1.28,
  );
  const mobilePortraitHeight = clampMetric(
    69 + Math.max(0, 0.82 - ratio) * 18 + Math.max(0, chestCoverage - 0.58) * 12,
    68,
    76,
  );
  const mobilePortraitDrop = clampMetric(5 + Math.max(0, 0.82 - ratio) * 18, 5, 13);
  const mobilePortraitRight = -clampMetric(
    11 + Math.max(0, ratio - 0.82) * 24 + Math.max(0, 0.92 - bounds.visibleRight) * 12,
    11,
    18,
  );
  const mobilePortraitShiftX = clampMetric(Math.max(0, ratio - 0.9) * 8 + Math.max(0, 0.95 - bounds.visibleRight) * 14, 0, 4.2);
  const desktopPortraitScale = clampMetric(
    1.01 + Math.max(0, 0.84 - ratio) * 0.12 + Math.max(0, waistCoverage - 0.68) * 0.08,
    1.01,
    1.08,
  );
  const desktopPortraitShiftX = -clampMetric(
    5.3 + Math.max(0, visualCenter - 0.5) * 34 + Math.max(0, headLeft - 0.34) * 10 + upperIntrusion * 9,
    5.3,
    13.8,
  );

  return [
    `--hero-copy-start: ${quoteStart.toFixed(2)}rem;`,
    `--hero-copy-width: ${quoteWidth.toFixed(2)}rem;`,
    `--hero-portrait-headroom: ${portraitHeadroom.toFixed(2)}rem;`,
    `--hero-portrait-drop: ${portraitDrop.toFixed(2)}%;`,
    `--hero-portrait-headroom-mobile: ${mobilePortraitHeadroom.toFixed(2)}rem;`,
    `--hero-mobile-copy-width: ${mobileCopyWidth.toFixed(2)}%;`,
    `--hero-mobile-portrait-width: ${mobilePortraitWidth.toFixed(2)}%;`,
    `--hero-mobile-portrait-height: ${mobilePortraitHeight.toFixed(2)}%;`,
    `--hero-portrait-scale-mobile: ${mobilePortraitScale.toFixed(3)};`,
    `--hero-portrait-drop-mobile: ${mobilePortraitDrop.toFixed(2)}%;`,
    `--hero-mobile-portrait-right: ${mobilePortraitRight.toFixed(2)}%;`,
    `--hero-portrait-shift-x-mobile: ${mobilePortraitShiftX.toFixed(2)}%;`,
    `--hero-portrait-scale-desktop: ${desktopPortraitScale.toFixed(3)};`,
    `--hero-portrait-shift-x-desktop: ${desktopPortraitShiftX.toFixed(2)}%;`,
  ].join(' ');
}

function getHeroQuoteSize(value: string) {
  const compactedLength = value.replace(/\s+/g, ' ').trim().length;

  if (compactedLength > 170) {
    return 'compact';
  }

  if (compactedLength > 120) {
    return 'medium';
  }

  return 'poster';
}

function getWordParts(value: string) {
  return value.trim().split(/\s+/u).filter(Boolean);
}

function getWordRevealTiming(wordCount: number) {
  const safeCount = Math.max(wordCount, 1);
  const duration = 400;
  const totalWindow = 720;
  const stagger = safeCount > 1
    ? Math.max(18, Math.min(46, Math.round((totalWindow - duration) / (safeCount - 1))))
    : 0;
  return { stagger, duration };
}

function getWordRevealStyle(wordCount: number) {
  const { stagger, duration } = getWordRevealTiming(wordCount);
  return `--word-reveal-stagger: ${stagger}ms; --word-reveal-duration: ${duration}ms;`;
}

function getMythPrompt(mythNumber?: number) {
  return mythNumber ? `Заблуждение #${mythNumber}` : 'Заблуждение';
}

function getMythContextParts(value: string) {
  const match = value.match(/заблуждени[а-я]*/iu);
  if (!match || typeof match.index !== 'number') {
    return {
      before: value,
      accent: '',
      after: '',
    };
  }

  return {
    before: value.slice(0, match.index),
    accent: match[0],
    after: value.slice(match.index + match[0].length),
  };
}

function normalizeLookupValue(value: string) {
  return value.replace(/\s+/g, ' ').trim().toLowerCase();
}

function findHeroEvent(match: string) {
  const lookup = normalizeLookupValue(match);
  return events.find((event) => normalizeLookupValue(event.title).includes(lookup));
}

function buildHeroVariants(): HeroVariant[] {
  const usedQuoteSlots = new Set<string>();
  const quoteVariants = [...HERO_QUOTE_VARIANT_SPECS]
    .sort((left, right) => right.priority - left.priority)
    .flatMap((spec) => {
    const event = findHeroEvent(spec.eventMatch);

    if (!event || !event.image || !event.speakerLabel || !event.speakerImages.length) {
      return [];
    }

    const slotKey = `${spec.quoteType}:${event.slug}`;
    if (usedQuoteSlots.has(slotKey)) {
      return [];
    }

    usedQuoteSlots.add(slotKey);

    return [{
      id: spec.id,
      kind: 'quote',
      quoteType: spec.quoteType,
      prompt: spec.prompt,
      priority: spec.priority,
      title: event.title,
      eventHref: spec.quoteType === 'lecture' ? `#event-${event.slug}` : undefined,
      quote: spec.quote,
      quoteSize: getHeroQuoteSize(spec.quote),
      speakerName: event.speakerLabel,
      speakerRole: event.heroRole || getSpeakerCaption(event.affiliation) || '',
      speakerImage: getSpeakerStripImage(event.speakerLabel, event.speakerImages[0]),
      speakerStyle: getHeroPortraitStyle(event.speakerLabel) ?? '',
      speakerSceneStyle: [getHeroSceneStyle(getSpeakerStripImage(event.speakerLabel, event.speakerImages[0])), getHeroSceneOverride(event.speakerLabel)].filter(Boolean).join(' '),
    }] satisfies HeroQuoteVariant[];
  });

  const mythVariants = homepageHeroMyths.map((myth) => ({
    id: myth.id,
    kind: 'myth',
    prompt: getMythPrompt(myth.mythNumber),
    label: getMythPrompt(myth.mythNumber),
    mythNumber: myth.mythNumber,
    title: myth.text,
    body: myth.speakerLine,
    eventHref: myth.eventHref,
    themeHref: myth.routeHref,
    priority: Math.max(24, 120 - myth.priority),
  })) satisfies HeroMythVariant[];

  return [...quoteVariants, ...mythVariants];
}

function isHeroQuoteVariant(variant: HeroVariant): variant is HeroQuoteVariant {
  return variant.kind === 'quote';
}

function isHeroMythVariant(variant: HeroVariant): variant is HeroMythVariant {
  return variant.kind === 'myth';
}

const heroVariants = buildHeroVariants();
const fallbackHeroVariant: HeroMythVariant = {
  id: 'fallback',
  kind: 'myth',
  prompt: getMythPrompt(),
  label: getMythPrompt(),
  title: 'Советский Калининград — это только фон без живых человеческих историй.',
  body: '— этот маршрут по фестивалю собран как раз для того, чтобы увидеть, как из людей, мест и привычек складывалась новая область.',
  eventHref: programHref,
  themeHref: '/zaselenie-i-obzhivanie/',
  priority: 1,
};
const heroStoryVariants = heroVariants.length ? heroVariants : [fallbackHeroVariant];
const defaultHeroVariant = heroStoryVariants[0];
const defaultHeroIsQuote = isHeroQuoteVariant(defaultHeroVariant);
const defaultHeroIsMyth = isHeroMythVariant(defaultHeroVariant);
const defaultHeroShowsTitle = defaultHeroIsMyth;
const defaultHeroShowsBody = defaultHeroIsMyth;
const defaultHeroSceneStyle = defaultHeroIsQuote ? defaultHeroVariant.speakerSceneStyle ?? '' : '';
const defaultHeroQuoteSize = defaultHeroIsQuote ? defaultHeroVariant.quoteSize : 'image';
const defaultHeroWordParts = defaultHeroIsMyth ? getWordParts(defaultHeroVariant.title) : [];
const defaultHeroWordRevealStyle = defaultHeroIsMyth ? getWordRevealStyle(defaultHeroWordParts.length) : undefined;
const defaultHeroMythContext = defaultHeroIsMyth ? getMythContextParts(defaultHeroVariant.body) : null;
const heroVariantsPayload = JSON.stringify(heroStoryVariants);
---

<Layout
  title="80 историй о главном | Фестиваль Российского общества Знание"
  description="Просветительский фестиваль к 80-летию Калининградской области: лекции, открытые диалоги, выставки и сильные истории о людях, памяти и культурном коде региона."
>
  <div class="page">
    <div id="top" aria-hidden="true"></div>
    <SiteHeader isHome routeItems={routeItems} programHref={programHref} />

    <main>
      <section class="hero">
        <div class="container">
          <div class="hero__shell">
            <div class="hero__copy">
              <p class="eyebrow">Просветительский фестиваль Российского общества Знание</p>
              <p class="hero__kicker">К 80-летию Калининградской области</p>
              <h1 class="hero__brand">
                <span class="sr-only">80 историй о главном</span>
                <img src="/shared-assets/logo-80-istorii-hero.svg" alt="" width="431" height="373" decoding="async" fetchpriority="high" aria-hidden="true" />
              </h1>
              <p class="hero__lead">
                Истории людей, мест и привычек, из которых складывалась новая Калининградская область.
                Первый экран теперь чередует сильные цитаты и мифы, чтобы быстрее показать, о чём спорит фестиваль и с какой истории начать.
              </p>

              <div class="hero__meta" aria-label="Ключевые параметры фестиваля">
                <span>Калининград</span>
                <span>{festivalPeriodLabel}</span>
                <span>{events.length} событий в программе</span>
              </div>

              <div class="hero__actions">
                <a class="button button--primary" href={programHref}>Смотреть программу</a>
              </div>
              <a class="hero__utility-link" href="#interest-chooser-title">Выбрать маршрут по интересам</a>
            </div>

            <aside class="hero__aside" aria-label="Сильные истории фестиваля">
              <section
                class="hero-showcase"
                data-hero-showcase
                data-hero-kind={defaultHeroVariant.kind}
                data-hero-quote-type={defaultHeroIsQuote ? defaultHeroVariant.quoteType : 'myth'}
                data-hero-quote-size={defaultHeroQuoteSize}
                data-hero-variants={heroVariantsPayload}
                data-hero-index="0"
                style={defaultHeroSceneStyle}
              >
                <div class="hero-showcase__media" aria-hidden="true">
                  <div class="hero-showcase__brandbadge" aria-hidden="true">
                    <img src="/shared-assets/logo-80-istorii-hero.svg" alt="" width="431" height="373" decoding="async" loading="eager" />
                  </div>
                </div>

                <div class="hero__portrait-seam" data-hero-portrait-shell hidden={!defaultHeroIsQuote} aria-hidden="true">
                  <img
                    class="hero-showcase__portrait"
                    data-hero-portrait
                    src={defaultHeroIsQuote ? defaultHeroVariant.speakerImage : ''}
                    alt=""
                    loading="eager"
                    fetchpriority={defaultHeroIsQuote ? 'high' : undefined}
                    decoding="async"
                    style={defaultHeroIsQuote ? defaultHeroVariant.speakerStyle ?? '' : ''}
                  />
                </div>

                <div class="hero-showcase__card">
                  <div class="hero-showcase__shape-proxy" data-hero-shape-proxy hidden={!defaultHeroIsQuote} aria-hidden="true"></div>
                  <p class="hero-showcase__prompt" data-hero-prompt>{defaultHeroVariant.prompt}</p>

                  <div class="hero-showcase__content">
                    <div class="hero-showcase__quote-mark" data-hero-quote-mark hidden={!defaultHeroIsQuote} aria-hidden="true">
                      <svg viewBox="0 0 16 16" role="presentation" focusable="false">
                        <path d="M5.29289 1.29291L6.70711 2.70712L3 6.41423V7.00001H7V14H1V5.5858L5.29289 1.29291Z"></path>
                        <path d="M15 7.00001H11V6.41423L14.7071 2.70712L13.2929 1.29291L9 5.5858V14H15V7.00001Z"></path>
                      </svg>
                    </div>

                    <blockquote class="hero-showcase__quote" data-hero-quote-shell hidden={!defaultHeroIsQuote}>
                      <p data-hero-quote>{defaultHeroIsQuote ? defaultHeroVariant.quote : ''}</p>
                    </blockquote>

                    <h2
                      class="hero-showcase__title word-reveal"
                      data-hero-title
                      hidden={!defaultHeroShowsTitle}
                      style={defaultHeroWordRevealStyle}
                    >
                      {defaultHeroIsMyth
                        ? defaultHeroWordParts.map((word, index) => (
                          <>
                            <span class="word-reveal__word" style={`--word-index: ${index};`}>{word}</span>
                            {index < defaultHeroWordParts.length - 1 && ' '}
                          </>
                        ))
                        : ''}
                    </h2>

                    <p class="hero-showcase__body" data-hero-body hidden={!defaultHeroShowsBody}>
                      {defaultHeroIsMyth && defaultHeroMythContext
                        ? (
                          <>
                            {defaultHeroMythContext.before}
                            {defaultHeroMythContext.accent && <span class="myth-context__accent">{defaultHeroMythContext.accent}</span>}
                            {defaultHeroMythContext.after}
                          </>
                        )
                        : ''}
                    </p>

                    <div class="hero-showcase__speaker" data-hero-speaker-shell hidden={!defaultHeroIsQuote}>
                      <strong data-hero-speaker-name>{defaultHeroIsQuote ? defaultHeroVariant.speakerName : ''}</strong>
                      <span data-hero-speaker-role hidden={!defaultHeroIsQuote || !defaultHeroVariant.speakerRole}>{defaultHeroIsQuote ? defaultHeroVariant.speakerRole : ''}</span>
                    </div>

                    <div class="hero-showcase__actions">
                      <a
                        class="hero-showcase__event-link"
                        data-hero-event-link
                        href={defaultHeroIsQuote ? (defaultHeroVariant.eventHref ?? programHref) : defaultHeroVariant.eventHref}
                      >
                        {defaultHeroIsQuote ? 'К лекции' : 'К событию'}
                      </a>
                      <a
                        class="hero-showcase__theme-link"
                        data-hero-theme-link
                        data-hero-theme-cta
                        href={defaultHeroIsMyth ? defaultHeroVariant.themeHref : undefined}
                        hidden={!defaultHeroIsMyth}
                      >
                        {defaultHeroIsMyth ? 'Больше мифов по теме' : ''}
                      </a>
                      {heroStoryVariants.length > 1 && (
                        <button class="hero-showcase__next" type="button" data-hero-next aria-label="Показать другую историю первого экрана">
                          Другая история
                        </button>
                      )}
                    </div>
                  </div>
                </div>
              </section>
            </aside>
          </div>
        </div>
      </section>

      <SpeakerPoster entries={speakerShowcase} totalCount={allSpeakerShowcase.length} loadHref={speakerLoadHref} />

      <InterestChooser items={routeItems} />

      {openDialogues.length > 0 && (
        <section class="section section--dialogues" id="dialogues" aria-labelledby="dialogues-title">
          <div class="container">
            <div class="section__header section__header--split section__header--dialogues">
              <div>
                <p class="section__eyebrow">Открытые диалоги</p>
                <h2 id="dialogues-title">Дискуссии с экспертами и теми, кто жил или хорошо знает советскую эпоху.</h2>
              </div>
              <p class="section__text">
                На каждую встречу приглашены 3-4 гостя. Вместе с модератором они обсудят тему,
                а по регламенту можно будет задавать вопросы из зала. Будет действительно интересно.
              </p>
            </div>

            <div class="dialogue-strip dialogue-strip--feature">
              {openDialogues.map((event) => (
                <a class="dialogue-card dialogue-card--feature" href={`#event-${event.slug}`}>
                  <span class="dialogue-card__meta">{event.dateLabel}</span>
                  <strong>{event.title}</strong>
                  <span>{event.venue}</span>
                </a>
              ))}
            </div>
          </div>
        </section>
      )}

      <section class="section section--program" id="program">
        <div class="container">
          <div class="section__header section__header--split">
            <div>
              <p class="section__eyebrow">Программа</p>
              <h2>Вся лента должна сканироваться быстро: дата, картинка, спикер и минимум ключевой информации</h2>
            </div>
            <p class="section__text">
              На десктопе перестраиваю список в плотный image-first ритм. Длинные абзацы убраны из первого экрана карточки,
              а на первый план выходят дата, афиша события и заметный человек.
            </p>
          </div>

          <div class="month-nav-wrap">
            <nav class="month-nav" aria-label="Навигация по месяцам">
              {monthGroups.map((group) => (
                <a href={`#month-${group.anchor}`}>{group.label}</a>
              ))}
            </nav>
          </div>

          <div class="program">
            {monthGroups.map((group) => (
              <section class="month-block" id={`month-${group.anchor}`}>
                <header class="month-block__header">
                  <div>
                    <p class="month-block__eyebrow">2026</p>
                    <h3>{group.label}</h3>
                  </div>
                  <span class="month-block__count">{group.events.length} событий</span>
                </header>

                <div class="event-list">
                  {group.events.map((event) => (
                    <EventCard event={event} now={now} />
                  ))}
                </div>
              </section>
            ))}
          </div>
        </div>
      </section>
    </main>

    <SiteFooter routeItems={routeItems} programHref={programHref} isHome />
  </div>

  <script is:inline>
    const heroShowcase = document.querySelector('[data-hero-showcase]');
    const interestChooser = document.querySelector('[data-interest-chooser]');
    const interestZone = document.querySelector('[data-interest-zone]');
    const programSection = document.querySelector('#program');
    const DESKTOP_HERO_AUTOPLAY_MS = 9000;

    let cachedHeaderHeight = 64;
    let chooserSyncFrame = 0;

    const updateHeaderHeight = () => {
      const rootStyle = getComputedStyle(document.documentElement);
      cachedHeaderHeight = Number.parseFloat(rootStyle.getPropertyValue('--site-header-height')) || 64;
    };

    const syncInterestChooserState = () => {
      if (!(interestChooser instanceof HTMLElement) || !(interestZone instanceof HTMLElement) || !(programSection instanceof HTMLElement)) {
        return;
      }

      const stickTop = cachedHeaderHeight + 8;
      const zoneTop = interestZone.getBoundingClientRect().top;
      const programTop = programSection.getBoundingClientRect().top;
      const isProgramActive = programTop <= stickTop + 28;
      const isChooserStuck = zoneTop <= stickTop && !isProgramActive;

      interestChooser.dataset.hidden = isProgramActive ? 'true' : 'false';
      interestChooser.dataset.stuck = isChooserStuck ? 'true' : 'false';
    };

    const scheduleInterestChooserSync = () => {
      if (chooserSyncFrame) {
        return;
      }

      chooserSyncFrame = window.requestAnimationFrame(() => {
        chooserSyncFrame = 0;
        syncInterestChooserState();
      });
    };

    if (interestChooser instanceof HTMLElement && interestZone instanceof HTMLElement && programSection instanceof HTMLElement) {
      updateHeaderHeight();
      syncInterestChooserState();
      window.addEventListener('load', scheduleInterestChooserSync);
      window.addEventListener('scroll', scheduleInterestChooserSync, { passive: true });
      window.addEventListener('resize', () => {
        updateHeaderHeight();
        scheduleInterestChooserSync();
      });
    }

    const buildWeightedDeck = (variants) => {
      const weightedShuffle = (pool) => {
        const remaining = pool.map((item) => ({
          ...item,
          weight: Math.max(Number(item.priority) || 1, 1),
        }));
        const deck = [];

        while (remaining.length) {
          const totalWeight = remaining.reduce((sum, item) => sum + item.weight, 0);
          let target = Math.random() * totalWeight;
          let selectedIndex = remaining.length - 1;

          for (let index = 0; index < remaining.length; index += 1) {
            target -= remaining[index].weight;
            if (target <= 0) {
              selectedIndex = index;
              break;
            }
          }

          deck.push(remaining[selectedIndex]);
          remaining.splice(selectedIndex, 1);
        }

        return deck;
      };

      const quotes = weightedShuffle(
        variants
          .map((variant, index) => ({ ...variant, index }))
          .filter((variant) => variant.kind === 'quote'),
      );
      const myths = weightedShuffle(
        variants
          .map((variant, index) => ({ ...variant, index }))
          .filter((variant) => variant.kind === 'myth'),
      );
      const deck = [];
      let expectsQuote = quotes.length > 0;

      while (quotes.length || myths.length) {
        if (expectsQuote && quotes.length) {
          deck.push(quotes.shift().index);
        } else if (!expectsQuote && myths.length) {
          deck.push(myths.shift().index);
        } else if (quotes.length) {
          deck.push(quotes.shift().index);
        } else if (myths.length) {
          deck.push(myths.shift().index);
        }

        expectsQuote = !expectsQuote;
      }

      return deck;
    };

    let heroSwitchTimer = 0;
    let heroAutoplayTimer = 0;

    const getWordRevealTiming = (wordCount) => {
      const safeCount = Math.max(Number(wordCount) || 1, 1);
      const duration = 400;
      const totalWindow = 720;
      const stagger = safeCount > 1
        ? Math.max(18, Math.min(46, Math.round((totalWindow - duration) / (safeCount - 1))))
        : 0;
      return { stagger, duration };
    };

    const setWordRevealText = (element, text, animate) => {
      if (!(element instanceof HTMLElement)) {
        return;
      }

      const words = String(text ?? '').trim().split(/\s+/u).filter(Boolean);
      element.textContent = '';
      element.classList.add('word-reveal');
      const { stagger, duration } = getWordRevealTiming(words.length);
      element.style.setProperty('--word-reveal-stagger', `${stagger}ms`);
      element.style.setProperty('--word-reveal-duration', `${duration}ms`);

      if (!words.length) {
        return;
      }

      const fragment = document.createDocumentFragment();
      words.forEach((word, index) => {
        const span = document.createElement('span');
        span.className = 'word-reveal__word';
        span.style.setProperty('--word-index', String(index));
        span.textContent = word;
        if (!animate) {
          span.dataset.static = 'true';
        }
        fragment.append(span);
        if (index < words.length - 1) {
          fragment.append(document.createTextNode(' '));
        }
      });

      element.append(fragment);
    };

    const setMythContextText = (element, text) => {
      if (!(element instanceof HTMLElement)) {
        return;
      }

      const value = String(text ?? '');
      const match = value.match(/заблуждени[а-я]*/iu);
      element.textContent = '';

      if (!match || typeof match.index !== 'number') {
        element.textContent = value;
        return;
      }

      element.append(document.createTextNode(value.slice(0, match.index)));
      const accent = document.createElement('span');
      accent.className = 'myth-context__accent';
      accent.textContent = match[0];
      element.append(accent);
      element.append(document.createTextNode(value.slice(match.index + match[0].length)));
    };

    const setHeroVariant = (root, variant, deckIndex, total) => {
      root.dataset.heroKind = variant.kind;
      root.dataset.heroQuoteType = variant.kind === 'quote' ? variant.quoteType : 'myth';
      root.dataset.heroQuoteSize = variant.kind === 'quote' ? variant.quoteSize : 'image';
      root.dataset.heroIndex = String(deckIndex);

      const heroShell = root.closest('.hero__shell');
      const quoteMark = root.querySelector('[data-hero-quote-mark]');
      const portraitShell = heroShell?.querySelector('[data-hero-portrait-shell]');
      const portrait = heroShell?.querySelector('[data-hero-portrait]');
      const shapeProxy = root.querySelector('[data-hero-shape-proxy]');
      const prompt = root.querySelector('[data-hero-prompt]');
      const title = root.querySelector('[data-hero-title]');
      const quoteShell = root.querySelector('[data-hero-quote-shell]');
      const quote = root.querySelector('[data-hero-quote]');
      const body = root.querySelector('[data-hero-body]');
      const speakerShell = root.querySelector('[data-hero-speaker-shell]');
      const speakerName = root.querySelector('[data-hero-speaker-name]');
      const speakerRole = root.querySelector('[data-hero-speaker-role]');
      const eventLink = root.querySelector('[data-hero-event-link]');
      const themeLink = root.querySelector('[data-hero-theme-link]');
      const isQuoteVariant = variant.kind === 'quote';
      const isMythVariant = variant.kind === 'myth';
      const showsTitle = isMythVariant;
      const showsBody = isMythVariant && Boolean(variant.body);
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      root.style.cssText = isQuoteVariant ? variant.speakerSceneStyle || '' : '';

      if (prompt instanceof HTMLElement) {
        prompt.textContent = variant.prompt;
      }

      if (title instanceof HTMLElement) {
        title.hidden = !showsTitle;
        if (showsTitle) {
          setWordRevealText(title, variant.title, !prefersReducedMotion);
        } else {
          title.textContent = '';
        }
      }

      if (body instanceof HTMLElement) {
        body.hidden = !showsBody;
        if (showsBody) {
          setMythContextText(body, variant.body);
        } else {
          body.textContent = '';
        }
      }

      if (quoteMark instanceof HTMLElement) {
        quoteMark.hidden = !isQuoteVariant;
      }

      if (quoteShell instanceof HTMLElement) {
        quoteShell.hidden = !isQuoteVariant;
      }

      if (shapeProxy instanceof HTMLElement) {
        shapeProxy.hidden = !isQuoteVariant;
      }

      if (speakerShell instanceof HTMLElement) {
        speakerShell.hidden = !isQuoteVariant;
      }

      if (portraitShell instanceof HTMLElement) {
        portraitShell.hidden = !isQuoteVariant;
      }

      if (eventLink instanceof HTMLAnchorElement) {
        const eventHref = isQuoteVariant
          ? (variant.quoteType === 'lecture' && variant.eventHref ? variant.eventHref : '#program')
          : variant.eventHref;
        eventLink.href = eventHref;
        eventLink.textContent = isQuoteVariant ? 'К лекции' : 'К событию';
      }

      if (themeLink instanceof HTMLAnchorElement) {
        themeLink.hidden = !isMythVariant;
        if (isMythVariant) {
          themeLink.href = variant.themeHref;
          themeLink.textContent = 'Больше мифов по теме';
        } else {
          themeLink.removeAttribute('href');
          themeLink.textContent = '';
        }
      }

      if (isQuoteVariant) {
        if (quote instanceof HTMLElement) {
          quote.textContent = variant.quote;
        }

        if (speakerName instanceof HTMLElement) {
          speakerName.textContent = variant.speakerName;
        }

        if (speakerRole instanceof HTMLElement) {
          speakerRole.textContent = variant.speakerRole;
          speakerRole.hidden = !variant.speakerRole;
        }

        if (portrait instanceof HTMLImageElement) {
          portrait.src = variant.speakerImage;
          portrait.style.cssText = variant.speakerStyle || '';
        }
      } else if (isMythVariant) {
        if (quote instanceof HTMLElement) {
          quote.textContent = '';
        }

        if (speakerName instanceof HTMLElement) {
          speakerName.textContent = '';
        }

        if (speakerRole instanceof HTMLElement) {
          speakerRole.textContent = '';
        }

        if (portrait instanceof HTMLImageElement) {
          portrait.removeAttribute('src');
          portrait.style.cssText = '';
        }
      }
    };

    const queueHeroVariant = (root, variant, deckIndex, total) => {
      if (heroSwitchTimer) {
        window.clearTimeout(heroSwitchTimer);
      }

      root.dataset.switching = 'true';

      heroSwitchTimer = window.setTimeout(() => {
        setHeroVariant(root, variant, deckIndex, total);
        root.dataset.switching = 'false';
        heroSwitchTimer = 0;
      }, 220);
    };

    const hydrateHeroShowcase = () => {
      if (!(heroShowcase instanceof HTMLElement) || !heroShowcase.dataset.heroVariants) {
        return;
      }

      const nextButton = heroShowcase.querySelector('[data-hero-next]');

      try {
        const variants = JSON.parse(heroShowcase.dataset.heroVariants);
        if (!Array.isArray(variants) || !variants.length) {
          return;
        }

        let deck = buildWeightedDeck(variants);
        let deckIndex = 0;
        let userInteracted = false;
        let heroHovered = false;
        let heroInViewport = true;
        let pageVisible = document.visibilityState === 'visible';
        const isMobile = window.matchMedia('(max-width: 759px), (pointer: coarse)').matches;
        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const stopAutoplay = () => {
          if (heroAutoplayTimer) {
            window.clearTimeout(heroAutoplayTimer);
            heroAutoplayTimer = 0;
          }
        };
        const canAutoplay = () =>
          !isMobile
          && !prefersReducedMotion
          && deck.length >= 2
          && !userInteracted
          && !heroHovered
          && heroInViewport
          && pageVisible;
        const startAutoplay = () => {
          if (!canAutoplay()) {
            stopAutoplay();
            return;
          }

          stopAutoplay();

          heroAutoplayTimer = window.setTimeout(() => {
            deckIndex += 1;
            if (deckIndex >= deck.length) {
              deck = buildWeightedDeck(variants);
              deckIndex = 0;
            }
            queueHeroVariant(heroShowcase, variants[deck[deckIndex]], deckIndex, variants.length);
            startAutoplay();
          }, DESKTOP_HERO_AUTOPLAY_MS);
        };

        setHeroVariant(heroShowcase, variants[deck[deckIndex]], deckIndex, variants.length);
        startAutoplay();

        if (nextButton instanceof HTMLButtonElement && variants.length > 1) {
          nextButton.addEventListener('click', () => {
            userInteracted = true;
            stopAutoplay();
            deckIndex = (deckIndex + 1) % deck.length;
            queueHeroVariant(heroShowcase, variants[deck[deckIndex]], deckIndex, variants.length);
          });
        }

        heroShowcase.addEventListener('mouseenter', () => {
          heroHovered = true;
          stopAutoplay();
        });

        heroShowcase.addEventListener('mouseleave', () => {
          heroHovered = false;
          startAutoplay();
        });

        const heroObserver = new IntersectionObserver((entries) => {
          const nextState = entries.some((entry) => entry.isIntersecting && entry.intersectionRatio >= 0.35);
          heroInViewport = nextState;
          if (heroInViewport) {
            startAutoplay();
          } else {
            stopAutoplay();
          }
        }, { threshold: [0, 0.35, 0.6] });

        heroObserver.observe(heroShowcase);

        document.addEventListener('visibilitychange', () => {
          pageVisible = document.visibilityState === 'visible';
          if (pageVisible) {
            startAutoplay();
          } else {
            stopAutoplay();
          }
        });
      } catch (error) {
        console.error('Hero showcase randomizer failed', error);
      }
    };

    hydrateHeroShowcase();

    const cycleNodes = Array.from(document.querySelectorAll('[data-portrait-frames]'));
    const timers = new Map();

    const startCycle = (node) => {
      if (timers.has(node)) return;

      const frames = (node.dataset.portraitFrames || '').split('|').filter(Boolean);
      const images = Array.from(node.querySelectorAll('.portrait-cycle__image'));

      if (frames.length < 2 || images.length < 2) {
        return;
      }

      let visibleIndex = 0;
      let frameIndex = 1;

      const tick = () => {
        const nextVisibleIndex = visibleIndex === 0 ? 1 : 0;
        const current = images[visibleIndex];
        const next = images[nextVisibleIndex];

        next.src = frames[frameIndex];
        window.requestAnimationFrame(() => {
          next.classList.add('is-active');
          current.classList.remove('is-active');
        });

        visibleIndex = nextVisibleIndex;
        frameIndex = (frameIndex + 1) % frames.length;
      };

      const timer = window.setInterval(tick, 5200);
      timers.set(node, timer);
    };

    const stopCycle = (node) => {
      const timer = timers.get(node);
      if (timer) {
        window.clearInterval(timer);
        timers.delete(node);
      }
    };

    const allowPortraitCycles = !window.matchMedia('(prefers-reduced-motion: reduce), (max-width: 759px), (pointer: coarse)').matches;

    if (allowPortraitCycles) {
      const observer = new IntersectionObserver((entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            startCycle(entry.target);
          } else {
            stopCycle(entry.target);
          }
        }
      }, { threshold: 0.45 });

      cycleNodes.forEach((node) => observer.observe(node));
    }
  </script>
  <RegistrationClient />
</Layout>

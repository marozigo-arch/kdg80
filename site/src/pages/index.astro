<Layout
  title="80 историй о главном | Фестиваль Российского общества Знание"
  description="Просветительский фестиваль к 80-летию Калининградской области: лекции, диалоги, выставки и сильные истории о людях, памяти и культурном коде региона."
>
  <div class="page">
    <div id="top" aria-hidden="true"></div>

    <header class="site-header" data-scrolled="false" data-logo-ready="false">
      <div class="container site-header__row">
        <a class="site-header__logo" href="#top" aria-label="Российское общество Знание, фестиваль 80 историй о главном">
          <span class="site-header__logo-shell" aria-hidden="true">
            <span class="site-header__logo-state site-header__logo-state--hero">
              <img src="/shared-assets/logo-znanie-main.svg" alt="" width="541" height="126" decoding="async" fetchpriority="high" />
            </span>
            <span class="site-header__logo-state site-header__logo-state--festival">
              <img src="/shared-assets/logo-znanie-festival.svg" alt="" width="877" height="150" decoding="async" />
            </span>
          </span>
        </a>

        <nav class="site-header__nav" aria-label="Быстрые разделы">
          <a href="#speakers">Спикеры</a>
          <a href="#program">Программа</a>
          <a href="#dialogues">Диалоги</a>
          <a href="#press">СМИ</a>
        </nav>

        <a class="button button--primary site-header__cta" href="#program">Программа</a>
      </div>
    </header>

    <main>
	      <section class="hero">
	        <div class="container">
	          <div class="hero__shell">
		            <div class="hero__copy">
		              <p class="eyebrow">Просветительский фестиваль Российского общества Знание</p>
		              <p class="hero__kicker">К 80-летию Калининградской области</p>
		              <h1 class="hero__brand">
		                <span class="sr-only">80 историй о главном</span>
		                <img src="/shared-assets/logo-80-istorii-hero.svg" alt="" width="431" height="373" decoding="async" fetchpriority="high" aria-hidden="true" />
		              </h1>
		              <p class="hero__lead">
		                Истории людей, мест и привычек, из которых складывалась новая Калининградская область.
		                Первый экран быстро отвечает, зачем идти на фестиваль и с какой лекции начать.
		              </p>

	              <div class="hero__meta" aria-label="Ключевые параметры фестиваля">
	                <span>Калининград</span>
	                <span>{festivalPeriodLabel}</span>
	                <span>{events.length} событий в программе</span>
	              </div>

		              <div class="hero__actions">
		                <a class="button button--primary" href="#program">Смотреть программу</a>
		                <a class="button button--ghost" href="#announces">Подписаться на анонсы</a>
		              </div>
		            </div>

	            <aside class="hero__aside" aria-label="Сильные истории фестиваля">
	              <section
	                class="hero-showcase"
	                data-hero-showcase
	                data-hero-kind={defaultHeroVariant.kind}
	                data-hero-quote-type={defaultHeroIsQuote ? defaultHeroVariant.quoteType : 'image'}
	                data-hero-variants={heroVariantsPayload}
	                data-hero-index="0"
	              >
	                <div class="hero-showcase__media" aria-hidden="true">
	                  <img
	                    class="hero-showcase__backdrop"
	                    data-hero-image
	                    src={defaultHeroVariant.image}
	                    alt=""
	                    loading="eager"
	                    decoding="async"
	                    fetchpriority="high"
	                    style={defaultHeroVariant.imageStyle ?? ''}
	                    hidden={defaultHeroIsQuote}
	                  />

	                  <div class="hero-showcase__brandbadge" aria-hidden="true">
	                    <img src="/shared-assets/logo-80-istorii-hero.svg" alt="" width="431" height="373" decoding="async" loading="eager" />
	                  </div>

	                  <div class="hero-showcase__quote-mark" data-hero-quote-mark hidden={!defaultHeroIsQuote}>“</div>
	                </div>

	                <div class="hero-showcase__card">
	                  <p class="hero-showcase__prompt" data-hero-prompt>{defaultHeroVariant.prompt}</p>

	                  <blockquote class="hero-showcase__quote" data-hero-quote-shell hidden={!defaultHeroIsQuote}>
	                    <p data-hero-quote>{defaultHeroIsQuote ? defaultHeroVariant.quote : ''}</p>
	                  </blockquote>

	                  <h2 class="hero-showcase__title" data-hero-title hidden={!defaultHeroShowsTitle}>{defaultHeroVariant.title}</h2>

	                  <p class="hero-showcase__body" data-hero-body hidden={!defaultHeroShowsBody}>
	                    {!defaultHeroIsQuote ? defaultHeroVariant.body : ''}
	                  </p>

	                  <div class="hero-showcase__speaker" data-hero-speaker-shell hidden={!defaultHeroIsQuote}>
	                    <strong data-hero-speaker-name>{defaultHeroIsQuote ? defaultHeroVariant.speakerName : ''}</strong>
	                    <span data-hero-speaker-role>{defaultHeroIsQuote ? defaultHeroVariant.speakerRole : ''}</span>
	                  </div>

	                  <div class="hero-showcase__actions">
	                    {heroStoryVariants.length > 1 && (
	                      <button class="hero-showcase__next" type="button" data-hero-next aria-label="Показать другую историю первого экрана">
	                        Другая история
	                      </button>
	                    )}
	                  </div>
	                </div>
	              </section>
		            </aside>

	            <div class="hero__portrait-seam" data-hero-portrait-shell hidden={!defaultHeroIsQuote} aria-hidden="true">
	              <img
	                class="hero-showcase__portrait"
	                data-hero-portrait
	                src={defaultHeroIsQuote ? defaultHeroVariant.speakerImage : ''}
	                alt=""
	                loading="eager"
	                decoding="async"
	                style={defaultHeroIsQuote ? defaultHeroVariant.speakerStyle ?? '' : ''}
	              />
	            </div>
		          </div>
		        </div>
		      </section>

	      <section class="hero-upcoming" aria-labelledby="next-event-title">
	        <div class="container">
	          <article class="hero-ticket hero-ticket--compact hero-ticket--bar">
	            <p class="hero-ticket__eyebrow">Ближайшее событие</p>
	            <h2 id="next-event-title">{nextEvent.title}</h2>
	            <div class="hero-ticket__meta">
	              <span>{nextEvent.dateLabel}</span>
	              <span>{nextEvent.timeLabel}</span>
	              <span>{nextEvent.venue}</span>
	            </div>
	            <p class="hero-ticket__summary">{getCardText(nextEvent)}</p>
	            <a class="button button--ghost" href={`#event-${nextEvent.slug}`}>К событию</a>
	          </article>
	        </div>
	      </section>

      <section class="section speaker-section" id="speakers">
        <div class="container">
          <div class="speaker-poster">
            <div class="speaker-poster__masthead">
              <div class="speaker-poster__topline">
                <p class="speaker-poster__eyebrow">Люди фестиваля</p>
                <p class="speaker-poster__stamp">Калининград / 2026 / 80 историй о главном</p>
              </div>

              <h2>
                <span>ГОЛОСА</span>
                <span>ФЕСТИВАЛЯ</span>
              </h2>

              <p class="speaker-poster__note">
                Крупные лица, резкий кроп, без карточного воздуха.
              </p>
            </div>

            <div
              class="speaker-strip"
              data-visible-count={SPEAKER_SHOWCASE_LIMIT}
              data-speakers={speakerShowcasePayload}
            >
              {speakerShowcase.map((speaker, index) => (
                <a class={`speaker-entry speaker-entry--${index + 1}`} href={`#${speaker.anchor}`}>
                  <div class="speaker-entry__meta">
                    <strong>{speaker.name}</strong>
                    {speaker.affiliation && <span>{getSpeakerCaption(speaker.affiliation)}</span>}
                  </div>

                  <div class="speaker-entry__media">
                    <img
                      class="speaker-entry__portrait"
                      src={getSpeakerStripImage(speaker.name, speaker.images[0])}
                      alt={speaker.name}
                      loading="lazy"
                      decoding="async"
                      style={getSpeakerStripStyle(speaker.name)}
                    />
                  </div>
                </a>
              ))}
            </div>
          </div>
        </div>
      </section>

      <section class="section section--compact" id="dialogues">
        <div class="container">
          <div class="section__header section__header--split">
            <div>
              <p class="section__eyebrow">Открытые диалоги</p>
              <h2>Их нужно выделять как отдельную драматургию фестиваля, а не как ещё один тип карточки</h2>
            </div>
            <p class="section__text">
              Здесь оставляю короткий ряд афишных анонсов: многоголосие, столкновение точек зрения и ощущение публичного разговора.
            </p>
          </div>

          <div class="dialogue-strip">
            {openDialogues.map((event) => (
              <a class="dialogue-card" href={`#event-${event.slug}`}>
                <span class="dialogue-card__meta">{event.dateLabel}</span>
                <strong>{event.title}</strong>
                <span>{event.venue}</span>
              </a>
            ))}
          </div>
        </div>
      </section>

      <section class="section section--program" id="program">
        <div class="container">
          <div class="section__header section__header--split">
            <div>
              <p class="section__eyebrow">Программа</p>
              <h2>Вся лента должна сканироваться быстро: дата, картинка, спикер и минимум ключевой информации</h2>
            </div>
            <p class="section__text">
              На десктопе перестраиваю список в плотный image-first ритм. Длинные абзацы убраны из первого экрана карточки,
              а на первый план выходят дата, афиша события и заметный человек.
            </p>
          </div>

          <div class="month-nav-wrap">
            <nav class="month-nav" aria-label="Навигация по месяцам">
              {monthGroups.map((group) => (
                <a href={`#month-${group.anchor}`}>{group.label}</a>
              ))}
            </nav>
          </div>

          <div class="program">
            {monthGroups.map((group) => (
              <section class="month-block" id={`month-${group.anchor}`}>
                <header class="month-block__header">
                  <div>
                    <p class="month-block__eyebrow">2026</p>
                    <h3>{group.label}</h3>
                  </div>
                  <span class="month-block__count">{group.events.length} событий</span>
                </header>

                <div class="event-list">
                  {group.events.map((event) => {
                    const dateParts = getDateParts(event.dateLabel);
                    const rangeDateParts = event.kind === 'range' ? getRangeDateParts(event.dateLabel) : null;
                    const isDialogueEvent = event.formatLabel.includes('Открытый диалог') && event.dialogueParticipants.length > 0;
                    const isSpecialEvent = event.kind === 'special';
                    const isRangeEvent = event.kind === 'range';
                    const isLecture = isLectureEvent(event.formatLabel);
                    const openingEvent = isOpeningEvent(event);
                    const stageImage = event.image || (openingEvent ? '/shared-assets/hero-added-09.webp' : '');
                    const useDialogueVisual = isDialogueEvent && !openingEvent;
                    const portraitImages = getEventPortraitImages(event.speakerLabel, event.speakerImages, isLecture);
                    const portraitFrames = getPortraitFrames(event.speakerLabel, event.speakerImages, isLecture);
                    const portraitStyle = getEventPortraitStyle(event.speakerLabel, isLecture);
                    const visualDialogueParticipants = useDialogueVisual
                      ? event.dialogueParticipants.filter((participant) => participant.images[0]).slice(0, 4)
                      : [];
                    const dialogueStageParticipants = visualDialogueParticipants.length
                      ? visualDialogueParticipants
                      : event.dialogueParticipants.slice(0, 4);
                    const cardText = getCardText(event);
                    const cardExtraText = getCardExtraText(event);
                    const hasExpandableCardSummary = hasExpandableSummary(event);
                    const useScientificLibraryVisitSchedule = usesScientificLibraryVisitSchedule(event);
                    const specialServiceLabels = isSpecialEvent
                      ? [
                          'Дата и время будут объявлены дополнительно',
                          event.showingsLabel,
                          event.registrationUrl ? 'Бесплатно, по регистрации' : 'Регистрация откроется позже',
                        ].filter(Boolean)
                      : [];

                    return (
                      <article class={`event-card ${event.speakerImages.length ? 'event-card--with-speaker' : ''} ${isLecture ? 'event-card--lecture' : ''} ${isDialogueEvent ? 'event-card--dialogue' : ''} ${isSpecialEvent ? 'event-card--special' : ''}`} id={`event-${event.slug}`}>
                        <div class="event-card__main">
                          <div class={`event-card__stage ${!useDialogueVisual && event.speakerImages.length > 0 ? 'event-card__stage--portrait' : ''}`}>
                            {isSpecialEvent ? (
                              <div class={`event-card__visual ${stageImage ? 'event-card__visual--special' : 'event-card__visual--plain event-card__visual--special'}`}>
                                {stageImage && (
                                  <img class="event-card__poster" src={stageImage} alt={`Афиша: ${event.title}`} loading="lazy" decoding="async" />
                                )}
                                <div class="event-card__overlay"></div>
                              </div>
                            ) : (
                              <>
                                <div class="event-card__date">
                                  {rangeDateParts ? (
                                    <>
                                      <span class="event-card__range-row">
                                        <span class="event-card__range-prefix">с</span>
                                        <span class="event-card__range-day">{rangeDateParts.startDay}</span>
                                        <span class="event-card__range-month">{rangeDateParts.startMonth}</span>
                                      </span>
                                      <span class="event-card__range-row">
                                        <span class="event-card__range-prefix">по</span>
                                        <span class="event-card__range-day">{rangeDateParts.endDay}</span>
                                        <span class="event-card__range-month">{rangeDateParts.endMonth}</span>
                                      </span>
                                    </>
                                  ) : (
                                    <>
                                      <span class="event-card__day">{dateParts.day}</span>
                                      <span class="event-card__month">{dateParts.month}</span>
                                      {dateParts.weekday && <span class="event-card__weekday">{dateParts.weekday}</span>}
                                      <span class="event-card__time">{event.timeLabel}</span>
                                    </>
                                  )}
                                </div>

                                {useDialogueVisual ? (
                                  <div
                                    class="event-card__dialogue-visual"
                                    aria-label={`Участники события ${event.title}`}
                                    style={`--dialogue-columns: ${Math.max(dialogueStageParticipants.length, 1)}`}
                                  >
                                    {dialogueStageParticipants.map((participant) => (
                                      <div class={`event-card__dialogue-person ${participant.images[0] ? '' : 'event-card__dialogue-person--placeholder'}`}>
                                        <div class="event-card__dialogue-meta">
                                          <strong>{participant.name}</strong>
                                        </div>
                                        <div class={`event-card__dialogue-media ${participant.images[0] ? '' : 'event-card__dialogue-media--placeholder'}`}>
                                          {participant.images[0] ? (
                                            <img
                                              class="event-card__dialogue-portrait"
                                              src={getDialoguePortraitImage(participant.name, participant.images[0])}
                                              alt={participant.name}
                                              loading="lazy"
                                              decoding="async"
                                              style={getDialoguePortraitStyle(participant.name)}
                                            />
                                          ) : (
                                            <span class="event-card__dialogue-placeholder" aria-hidden="true">
                                              {getDialogueMonogram(participant.name)}
                                            </span>
                                          )}
                                        </div>
                                      </div>
                                    ))}
                                  </div>
                                ) : (
                                  <>
                                    <div class={`event-card__visual ${stageImage ? '' : 'event-card__visual--plain'}`}>
                                      {stageImage && (
                                        <img class="event-card__poster" src={stageImage} alt={`Афиша: ${event.title}`} loading="lazy" decoding="async" />
                                      )}
                                      <div class="event-card__overlay"></div>

                                      {isLecture && (
                                        <div class="event-card__visual-copy">
                                          <p class={getLectureTitleClass(event.title)}>{event.title}</p>
                                        </div>
                                      )}
                                    </div>

                                    {event.speakerImages.length > 0 && (
                                      <div
                                        class="event-card__portrait portrait-cycle"
                                        data-portrait-frames={portraitFrames}
                                        style={portraitStyle}
                                      >
                                        <img
                                          class="portrait-cycle__image is-active"
                                          src={portraitImages[0]}
                                          alt={event.speakerLabel}
                                          loading="lazy"
                                          decoding="async"
                                        />
                                        {portraitImages.length > 1 && (
                                          <img
                                            class="portrait-cycle__image"
                                            src={portraitImages[1]}
                                            alt={event.speakerLabel}
                                            loading="lazy"
                                            decoding="async"
                                            aria-hidden="true"
                                          />
                                        )}
                                      </div>
                                    )}
                                  </>
                                )}
                              </>
                            )}
                          </div>

                          <div class="event-card__body">
                            <div class="event-card__body-head">
                              <div class="event-card__labels">
                                <span class="event-card__format event-card__format--body">{event.formatLabel}</span>
                                <span class="event-card__access event-card__access--free">Бесплатно</span>
                              </div>
                              {!isLecture && <h4 class="event-card__title">{event.title}</h4>}
                            </div>

                            {isDialogueEvent && (
                              <div class="event-card__cast">
                                {event.dialogueParticipants.map((participant) => (
                                  <span>{participant.name}</span>
                                ))}
                              </div>
                            )}

                            {!isDialogueEvent && !isSpecialEvent && event.speakerLabel && <p class="event-card__speaker">{event.speakerLabel}</p>}
                            {!isDialogueEvent && !isSpecialEvent && event.affiliation && <p class="event-card__affiliation">{event.affiliation}</p>}

                            {isRangeEvent && (
                              hasExpandableCardSummary ? (
                                <details class="event-card__summary-details">
                                  <summary class="event-card__summary-toggle">
                                    <span class="event-card__summary-text">{cardText}</span>
                                    <span class="event-card__summary-hint" aria-hidden="true"></span>
                                  </summary>
                                  {cardExtraText && <p class="event-card__summary-extra">{cardExtraText}</p>}
                                  {shouldShowQuestionBlock(event) && (
                                    <div class="event-card__question-block">
                                      <p class="event-card__question-label">О чём поговорим</p>
                                      <ul class="event-card__question-list">
                                        {event.questions.map((question) => (
                                          <li>{question}</li>
                                        ))}
                                      </ul>
                                    </div>
                                  )}
                                </details>
                              ) : (
                                <p class="event-card__summary-plain">{cardText}</p>
                              )
                            )}

                            {event.relatedEvent && (
                              <div class="event-card__related">
                                <p class="event-card__related-label">{event.relatedEvent.relationLabel}</p>
                                <a class="event-card__related-link" href={`#event-${event.relatedEvent.slug}`}>
                                  <strong>{event.relatedEvent.title}</strong>
                                  <span>{getRelatedMetaLine(event.relatedEvent)}</span>
                                  <span>{getRelatedSecondaryLine(event.relatedEvent)}</span>
                                </a>
                              </div>
                            )}

                            {isRangeEvent && (
                              <div class="event-card__range-info">
                                <span class="event-card__range-label">Период экспонирования</span>
                                <strong>{event.dateLabel}</strong>
                                <span class="event-card__range-detail">{getRangeVisitLabel(event, useScientificLibraryVisitSchedule)}</span>
                                {useScientificLibraryVisitSchedule && (
                                  <span class="event-card__range-detail">{SCIENTIFIC_LIBRARY_VISIT_SCHEDULE.sanitaryLabel}</span>
                                )}
                                <span class="event-card__range-detail">{event.venue} · {event.address}</span>
                                {useScientificLibraryVisitSchedule && (
                                  <a
                                    class="event-card__range-link"
                                    href={SCIENTIFIC_LIBRARY_VISIT_SCHEDULE.sourceUrl}
                                    target="_blank"
                                    rel="noreferrer"
                                  >
                                    {SCIENTIFIC_LIBRARY_VISIT_SCHEDULE.sourceLabel}
                                  </a>
                                )}
                              </div>
                            )}

                            {!isRangeEvent && (
                              hasExpandableCardSummary ? (
                                <details class="event-card__summary-details">
                                  <summary class="event-card__summary-toggle">
                                    <span class="event-card__summary-text">{cardText}</span>
                                    <span class="event-card__summary-hint" aria-hidden="true"></span>
                                  </summary>
                                  {cardExtraText && <p class="event-card__summary-extra">{cardExtraText}</p>}
                                  {shouldShowQuestionBlock(event) && (
                                    <div class="event-card__question-block">
                                      <p class="event-card__question-label">О чём поговорим</p>
                                      <ul class="event-card__question-list">
                                        {event.questions.map((question) => (
                                          <li>{question}</li>
                                        ))}
                                      </ul>
                                    </div>
                                  )}
                                </details>
                              ) : (
                                <p class="event-card__summary-plain">{cardText}</p>
                              )
                            )}

                            {isSpecialEvent && specialServiceLabels.length > 0 && (
                              <div class="event-card__service-meta" aria-label="Информация о спектакле">
                                {specialServiceLabels.map((label) => (
                                  <span>{label}</span>
                                ))}
                              </div>
                            )}

                            {!isRangeEvent && (
                              <div class="event-card__meta">
                                <span>{event.venue}</span>
                                <span>{event.address}</span>
                                {event.durationLabel && <span>{event.durationLabel}</span>}
                              </div>
                            )}

                            {isLecture && event.speakerLectureLinks.length > 0 && (
                              <div class="event-card__speaker-links" aria-label={`Другие лекции спикера ${event.speakerLabel}`}>
                                <span>Ещё у лектора:</span>
                                {event.speakerLectureLinks.map((lecture) => (
                                  <a href={`#event-${lecture.slug}`} title={lecture.dateLabel}>{lecture.title}</a>
                                ))}
                              </div>
                            )}
                          </div>

                          {!isRangeEvent && !isSpecialEvent && (
                            <aside class="event-card__actions">
                              {event.registrationUrl ? (
                                <a
                                  class="button button--primary"
                                  href={event.registrationUrl}
                                  target="_blank"
                                  rel="noreferrer"
                                >
                                  Регистрация
                                </a>
                              ) : (
                                <div class="notice">Дата спектакля будет объявлена позже.</div>
                              )}

                              {!isSpecialEvent && event.calendarReady ? (
                                <details class="calendar-menu">
                                  <summary class="button button--ghost">В календарь</summary>
                                  <div class="calendar-panel">
                                    <a class="calendar-link" href={event.icsUrl}>ICS</a>
                                    <a
                                      class="calendar-link"
                                      href={event.googleCalendarUrl}
                                      target="_blank"
                                      rel="noreferrer"
                                    >
                                      Google
                                    </a>
                                  </div>
                                </details>
                              ) : !isSpecialEvent && event.calendarNote ? (
                                <div class="notice">{event.calendarNote}</div>
                              ) : null}
                            </aside>
                          )}
                        </div>
                      </article>
                    );
                  })}
                </div>
              </section>
            ))}
          </div>
        </div>
      </section>

      <section class="section section--compact" id="announces">
        <div class="container footer-panels">
          <article class="footer-panel footer-panel--telegram">
            <div class="telegram-card">
              <div class="telegram-card__content">
                <span class="telegram-card__eyebrow">Канал анонсов</span>
                <h3>{TELEGRAM_CHANNEL_NAME}</h3>
                <p class="telegram-card__handle">{TELEGRAM_CHANNEL_HANDLE}</p>
                <p>В канале публикуем новые анонсы, изменения программы и короткие напоминания о событиях, чтобы важные обновления не потерялись в общей ленте.</p>
                <div class="footer-panel__actions telegram-card__actions">
                  <a
                    class="button button--primary"
                    href={TELEGRAM_ANNOUNCEMENT_URL}
                    data-telegram-deep-link={TELEGRAM_ANNOUNCEMENT_APP_URL}
                    data-telegram-web-url={TELEGRAM_ANNOUNCEMENT_URL}
                  >
                    Открыть канал в Telegram
                  </a>
                </div>
              </div>

              <a
                class="telegram-card__qr"
                href={TELEGRAM_ANNOUNCEMENT_URL}
                target="_blank"
                rel="noreferrer"
                aria-label={`Открыть Telegram-канал ${TELEGRAM_CHANNEL_NAME}`}
              >
                <img
                  src={TELEGRAM_QR_CODE_URL}
                  alt={`QR-код для перехода в Telegram-канал ${TELEGRAM_CHANNEL_NAME}`}
                  width="250"
                  height="250"
                  loading="lazy"
                  decoding="async"
                />
                <strong>Сканируйте с телефона</strong>
                <span>На десктопе QR открывает тот же канал без ручного поиска.</span>
              </a>
            </div>
          </article>

          <article class="footer-panel" id="press">
            <h3>Для СМИ</h3>
            <p>Официальный сайт просветительского фестиваля Российского общества Знание «80 историй о главном» к 80-летию Калининградской области.</p>
            <p>Для пресс-служб и редакций здесь должны быть базовые материалы без поиска по странице: положение фестиваля, официальный пресс-контакт и ссылка на актуальную программу.</p>
            <div class="footer-panel__actions">
              <a class="button button--ghost" href={FESTIVAL_REGULATION_URL} target="_blank" rel="noreferrer">
                Положение фестиваля PDF
              </a>
              <a class="button button--primary" href={`mailto:${PRESS_EMAIL}`}>
                {PRESS_EMAIL}
              </a>
            </div>
          </article>
        </div>
      </section>
    </main>
  </div>

  <script is:inline>
    const siteHeader = document.querySelector('.site-header');
    const heroShowcase = document.querySelector('[data-hero-showcase]');
    const speakerStrip = document.querySelector('.speaker-strip');
    const telegramAppLinks = Array.from(document.querySelectorAll('[data-telegram-deep-link]'));
    let headerStateFrame = 0;

    const getHeaderScrollThreshold = () => {
      if (!(siteHeader instanceof HTMLElement)) {
        return 24;
      }

      return siteHeader.offsetHeight + 24;
    };

    const syncHeaderLogoState = () => {
      if (!(siteHeader instanceof HTMLElement)) {
        return;
      }

      siteHeader.dataset.scrolled = window.scrollY > getHeaderScrollThreshold() ? 'true' : 'false';
    };

    const requestHeaderLogoStateSync = () => {
      if (headerStateFrame) {
        return;
      }

      headerStateFrame = window.requestAnimationFrame(() => {
        headerStateFrame = 0;
        syncHeaderLogoState();
      });
    };

    syncHeaderLogoState();
    window.requestAnimationFrame(() => {
      window.requestAnimationFrame(() => {
        if (siteHeader instanceof HTMLElement) {
          siteHeader.dataset.logoReady = 'true';
        }
      });
    });
    window.addEventListener('load', requestHeaderLogoStateSync);
    window.addEventListener('hashchange', requestHeaderLogoStateSync);
    window.addEventListener('scroll', requestHeaderLogoStateSync, { passive: true });
    window.addEventListener('resize', requestHeaderLogoStateSync);

    const shouldUseNativeNavigation = (event) => (
      event.defaultPrevented
      || event.button !== 0
      || event.metaKey
      || event.ctrlKey
      || event.shiftKey
      || event.altKey
    );

    const handleTelegramAppLink = (event) => {
      if (shouldUseNativeNavigation(event)) {
        return;
      }

      const link = event.currentTarget;
      if (!(link instanceof HTMLAnchorElement)) {
        return;
      }

      const appUrl = link.dataset.telegramDeepLink;
      const webUrl = link.dataset.telegramWebUrl || link.href;
      if (!appUrl) {
        return;
      }

      event.preventDefault();

      let appOpened = false;
      let fallbackTimer = 0;

      const cleanup = () => {
        document.removeEventListener('visibilitychange', handleVisibilityChange);
        if (fallbackTimer) {
          window.clearTimeout(fallbackTimer);
          fallbackTimer = 0;
        }
      };

      const handleVisibilityChange = () => {
        if (document.visibilityState === 'hidden') {
          appOpened = true;
          cleanup();
        }
      };

      document.addEventListener('visibilitychange', handleVisibilityChange);

      fallbackTimer = window.setTimeout(() => {
        cleanup();
        if (!appOpened) {
          window.location.href = webUrl;
        }
      }, 900);

      window.location.href = appUrl;
    };

    telegramAppLinks.forEach((link) => {
      link.addEventListener('click', handleTelegramAppLink);
    });

	    const buildWeightedDeck = (variants) => {
	      const remaining = variants
	        .map((variant, index) => ({
	          index,
	          weight: Math.max(Number(variant.priority) || 1, 1),
	        }));
	      const deck = [];

	      while (remaining.length) {
	        const totalWeight = remaining.reduce((sum, item) => sum + item.weight, 0);
	        let target = Math.random() * totalWeight;
	        let selectedIndex = 0;

	        for (let index = 0; index < remaining.length; index += 1) {
	          target -= remaining[index].weight;
	          if (target <= 0) {
	            selectedIndex = index;
	            break;
	          }
	        }

	        deck.push(remaining[selectedIndex].index);
	        remaining.splice(selectedIndex, 1);
	      }

	      return deck;
	    };

	    let heroSwitchTimer = 0;

	    const setHeroVariant = (root, variant, deckIndex, total) => {
	      root.dataset.heroKind = variant.kind;
	      root.dataset.heroQuoteType = variant.kind === 'quote' ? variant.quoteType : 'image';
	      root.dataset.heroIndex = String(deckIndex);

	      const heroShell = root.closest('.hero__shell');
	      const image = root.querySelector('[data-hero-image]');
	      const quoteMark = root.querySelector('[data-hero-quote-mark]');
	      const portraitShell = heroShell?.querySelector('[data-hero-portrait-shell]');
	      const portrait = heroShell?.querySelector('[data-hero-portrait]');
	      const prompt = root.querySelector('[data-hero-prompt]');
	      const title = root.querySelector('[data-hero-title]');
	      const quoteShell = root.querySelector('[data-hero-quote-shell]');
	      const quote = root.querySelector('[data-hero-quote]');
	      const body = root.querySelector('[data-hero-body]');
	      const speakerShell = root.querySelector('[data-hero-speaker-shell]');
	      const speakerName = root.querySelector('[data-hero-speaker-name]');
	      const speakerRole = root.querySelector('[data-hero-speaker-role]');
	      const isQuoteVariant = variant.kind === 'quote';
	      const showsTitle = !isQuoteVariant || variant.quoteType === 'lecture';
	      const showsBody = !isQuoteVariant && Boolean(variant.body);

	      if (image instanceof HTMLImageElement) {
	        image.hidden = isQuoteVariant;
	        if (isQuoteVariant) {
	          image.removeAttribute('src');
	          image.style.cssText = '';
	        } else {
	          image.src = variant.image;
	          image.style.cssText = variant.imageStyle || '';
	        }
	      }

	      if (prompt instanceof HTMLElement) {
	        prompt.textContent = variant.prompt;
	      }

	      if (title instanceof HTMLElement) {
	        title.hidden = !showsTitle;
	        title.textContent = showsTitle ? variant.title : '';
	      }

	      if (body instanceof HTMLElement) {
	        body.hidden = !showsBody;
	        body.textContent = showsBody ? variant.body : '';
	      }

	      if (quoteMark instanceof HTMLElement) {
	        quoteMark.hidden = !isQuoteVariant;
	      }

	      if (quoteShell instanceof HTMLElement) {
	        quoteShell.hidden = !isQuoteVariant;
	      }

      if (speakerShell instanceof HTMLElement) {
        speakerShell.hidden = !isQuoteVariant;
      }

	      if (portraitShell instanceof HTMLElement) {
	        portraitShell.hidden = !isQuoteVariant;
	      }

	      if (isQuoteVariant) {
	        if (quote instanceof HTMLElement) {
	          quote.textContent = variant.quote;
	        }

        if (speakerName instanceof HTMLElement) {
          speakerName.textContent = variant.speakerName;
        }

        if (speakerRole instanceof HTMLElement) {
          speakerRole.textContent = variant.speakerRole;
        }

	        if (portrait instanceof HTMLImageElement) {
	          portrait.src = variant.speakerImage;
	          portrait.style.cssText = variant.speakerStyle || '';
	        }
	      } else {
        if (quote instanceof HTMLElement) {
          quote.textContent = '';
        }

        if (speakerName instanceof HTMLElement) {
          speakerName.textContent = '';
        }

        if (speakerRole instanceof HTMLElement) {
          speakerRole.textContent = '';
        }

	        if (portrait instanceof HTMLImageElement) {
	          portrait.removeAttribute('src');
	          portrait.style.cssText = '';
	        }
	      }
	    };

    const queueHeroVariant = (root, variant, deckIndex, total) => {
      if (heroSwitchTimer) {
        window.clearTimeout(heroSwitchTimer);
      }

      root.dataset.switching = 'true';

      heroSwitchTimer = window.setTimeout(() => {
        setHeroVariant(root, variant, deckIndex, total);
        root.dataset.switching = 'false';
        heroSwitchTimer = 0;
      }, 140);
    };

    const hydrateHeroShowcase = () => {
      if (!(heroShowcase instanceof HTMLElement) || !heroShowcase.dataset.heroVariants) {
        return;
      }

      const nextButton = heroShowcase.querySelector('[data-hero-next]');

      try {
        const variants = JSON.parse(heroShowcase.dataset.heroVariants);
        if (!Array.isArray(variants) || !variants.length) {
          return;
        }

	        const deck = buildWeightedDeck(variants);
        let deckIndex = 0;

        setHeroVariant(heroShowcase, variants[deck[deckIndex]], deckIndex, variants.length);

        if (nextButton instanceof HTMLButtonElement && variants.length > 1) {
          nextButton.addEventListener('click', () => {
            deckIndex = (deckIndex + 1) % deck.length;
            queueHeroVariant(heroShowcase, variants[deck[deckIndex]], deckIndex, variants.length);
          });
        }
      } catch (error) {
        console.error('Hero showcase randomizer failed', error);
      }
    };

    hydrateHeroShowcase();

    const pickWeightedSpeakers = (pool, count) => {
      const available = [...pool];
      const selection = [];

      while (selection.length < count && available.length) {
        const totalWeight = available.reduce((sum, speaker) => sum + Math.max(Number(speaker.weight) || 1, 0.1), 0);
        let threshold = Math.random() * totalWeight;
        let selectedIndex = available.length - 1;

        for (let index = 0; index < available.length; index += 1) {
          threshold -= Math.max(Number(available[index].weight) || 1, 0.1);
          if (threshold <= 0) {
            selectedIndex = index;
            break;
          }
        }

        selection.push(available.splice(selectedIndex, 1)[0]);
      }

      return selection;
    };

    const buildSpeakerEntry = (speaker, index) => {
      const entry = document.createElement('a');
      entry.className = `speaker-entry speaker-entry--${index + 1}`;
      entry.href = `#${speaker.anchor}`;

      const meta = document.createElement('div');
      meta.className = 'speaker-entry__meta';

      const title = document.createElement('strong');
      title.textContent = speaker.name;
      meta.appendChild(title);

      if (speaker.affiliation) {
        const caption = document.createElement('span');
        caption.textContent = speaker.affiliation.replace(/\s+/g, ' ').trim();
        meta.appendChild(caption);
      }

      const media = document.createElement('div');
      media.className = 'speaker-entry__media';

      const image = document.createElement('img');
      image.className = 'speaker-entry__portrait';
      image.src = speaker.image;
      image.alt = speaker.name;
      image.loading = 'lazy';
      image.decoding = 'async';

      if (speaker.style) {
        image.style.cssText = speaker.style;
      }

      media.appendChild(image);
      entry.append(meta, media);

      return entry;
    };

    const hydrateSpeakerStrip = async () => {
      if (!speakerStrip?.dataset.speakers || speakerStrip.dataset.ready === 'true') {
        return;
      }

      speakerStrip.dataset.ready = 'true';

      try {
        const speakerPool = JSON.parse(speakerStrip.dataset.speakers);
        const visibleCount = Number.parseInt(speakerStrip.dataset.visibleCount || '', 10)
          || speakerStrip.children.length
          || 8;
        const selectedSpeakers = shuffleInPlace(
          pickWeightedSpeakers(speakerPool, Math.min(visibleCount, speakerPool.length)),
        );

        const fragment = document.createDocumentFragment();
        selectedSpeakers.forEach((speaker, index) => {
          fragment.appendChild(buildSpeakerEntry(speaker, index));
        });

        speakerStrip.replaceChildren(fragment);
      } catch (error) {
        console.error('Speaker showcase randomizer failed', error);
        speakerStrip.dataset.ready = 'false';
      }
    };

    if (speakerStrip?.dataset.speakers) {
      if ('IntersectionObserver' in window) {
        const observer = new IntersectionObserver((entries) => {
          if (!entries.some((entry) => entry.isIntersecting)) {
            return;
          }

          observer.disconnect();
          void hydrateSpeakerStrip();
        }, { rootMargin: '320px 0px' });

        observer.observe(speakerStrip);
      } else {
        window.setTimeout(() => {
          void hydrateSpeakerStrip();
        }, 0);
      }
    }

    const cycleNodes = Array.from(document.querySelectorAll('[data-portrait-frames]'));
    const timers = new Map();

    const startCycle = (node) => {
      if (timers.has(node)) return;

      const frames = (node.dataset.portraitFrames || '').split('|').filter(Boolean);
      const images = Array.from(node.querySelectorAll('.portrait-cycle__image'));

      if (frames.length < 2 || images.length < 2) {
        return;
      }

      let visibleIndex = 0;
      let frameIndex = 1;

      const tick = () => {
        const nextVisibleIndex = visibleIndex === 0 ? 1 : 0;
        const current = images[visibleIndex];
        const next = images[nextVisibleIndex];

        next.src = frames[frameIndex];
        window.requestAnimationFrame(() => {
          next.classList.add('is-active');
          current.classList.remove('is-active');
        });

        visibleIndex = nextVisibleIndex;
        frameIndex = (frameIndex + 1) % frames.length;
      };

      const timer = window.setInterval(tick, 5200);
      timers.set(node, timer);
    };

    const stopCycle = (node) => {
      const timer = timers.get(node);
      if (timer) {
        window.clearInterval(timer);
        timers.delete(node);
      }
    };

    const allowPortraitCycles = !window.matchMedia('(prefers-reduced-motion: reduce), (max-width: 759px), (pointer: coarse)').matches;

    if (allowPortraitCycles) {
      const observer = new IntersectionObserver((entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            startCycle(entry.target);
          } else {
            stopCycle(entry.target);
          }
        }
      }, { threshold: 0.45 });

      cycleNodes.forEach((node) => observer.observe(node));
    }
  </script>
</Layout>
